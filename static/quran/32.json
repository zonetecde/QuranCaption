.6","h":"17.9","c":"وَجَعَلۡنَٰهُ","d":"wajaʿalnāhu","e":"And We made it","i":"وَجَعَلۡنٰهُ"},{"b":"11.9","h":"20.39","c":"هُدٗى","d":"hudan","e":"a guide","i":"هُدًى"},{"b":"12.2","h":"21.14","c":"لِّبَنِيٓ","d":"libanī","e":"for the Children of Israel","i":"لِّبَنِىۡۤ"},{"b":"14.2","h":"23.88","c":"إِسۡرَـٰٓءِيلَ","d":"is'rāīla","e":"for the Children of Israel","i":"اِسۡرَآءِيۡلَۚ"}],"a":{"g":"And We certainly gave Moses the Scripture, so do not be in doubt over his meeting. And we made the Torah guidance for the Children of Israel."}},"24":{"w":[{"b":"0.04","h":"0.65","c":"وَجَعَلۡنَا","d":"wajaʿalnā","e":"And We made","i":"وَ جَعَلۡنَا"},{"b":"1.2","h":"2.75","c":"مِنۡهُمۡ","d":"min'hum","e":"from them","i":"مِنۡهُمۡ"},{"b":"1.9","h":"4.16","c":"أَئِمَّةٗ","d":"a-immatan","e":"leaders","i":"اَٮِٕمَّةً"},{"b":"4.2","h":"7.31","c":"يَهۡدُونَ","d":"yahdūna","e":"guiding","i":"يَّهۡدُوۡنَ"},{"b":"5.1","h":"9.1","c":"بِأَمۡرِنَا","d":"bi-amrinā","e":"by Our Command","i":"بِاَمۡرِنَا"},{"b":"6.2","h":"11.48","c":"لَمَّا","d":"lammā","e":"when","i":"لَمَّا"},{"b":"7.4","h":"13.3","c":"صَبَرُواْۖ","d":"ṣabarū","e":"they were patient","i":"صَبَرُوۡا​ؕ"},{"b":"8.6","h":"17.5","c":"وَكَانُواْ","d":"wakānū","e":"and they were","i":"وَ كَانُوۡا"},{"b":"9.5","h":"19.36","c":"بِـَٔايَٰتِنَا","d":"biāyātinā","e":"of Our Verses","i":"بِاٰيٰتِنَا"},{"b":"11.1","h":"22.55","c":"يُوقِنُونَ","d":"yūqinūna","e":"certain","i":"يُوۡقِنُوۡنَ"}],"a":{"g":"And We made from among them leaders guiding by Our command when they were patient and [when] they were certain of Our signs."}},"25":{"w":[{"b":"0.05","h":"0.8","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"1.0","h":"2.04","c":"رَبَّكَ","d":"rabbaka","e":"your Lord","i":"رَبَّكَ"},{"b":"1.7","h":"3.56","c":"هُوَ","d":"huwa","e":"[He]","i":"هُوَ"},{"b":"2.1","h":"4.28","c":"يَفۡصِلُ","d":"yafṣilu","e":"will judge","i":"يَفۡصِلُ"},{"b":"2.9","h":"5.77","c":"بَيۡنَهُمۡ","d":"baynahum","e":"between them","i":"بَيۡنَهُمۡ"},{"b":"3.8","h":"7.41","c":"يَوۡمَ","d":"yawma","e":"(on the) Day","i":"يَوۡمَ"},{"b":"4.4","h":"8.44","c":"ٱلۡقِيَٰمَةِ","d":"l-qiyāmati","e":"(of) Resurrection","i":"الۡقِيٰمَةِ"},{"b":"5.5","h":"10.58","c":"فِيمَا","d":"fīmā","e":"in what","i":"فِيۡمَا"},{"b":"6.2","h":"12","c":"كَانُواْ","d":"kānū","e":"they used (to)","i":"كَانُوۡا"},{"b":"7.0","h":"13.59","c":"فِيهِ","d":"fīhi","e":"[in it]","i":"فِيۡهِ"},{"b":"7.6","h":"14.85","c":"يَخۡتَلِفُونَ","d":"yakhtalifūna","e":"differ","i":"يَخۡتَلِفُوۡنَ"}],"a":{"g":"Indeed, your Lord will judge between them on the Day of Resurrection concerning that over which they used to differ."}},"26":{"w":[{"b":"0.03","h":"0.35","c":"أَوَلَمۡ","d":"awalam","e":"Does it not","i":"اَوَلَمۡ"},{"b":"0.67","h":"1.49","c":"يَهۡدِ","d":"yahdi","e":"guide","i":"يَهۡدِ"},{"b":"1.2","h":"2.69","c":"لَهُمۡ","d":"lahum","e":"[for] them","i":"لَهُمۡ"},{"b":"1.7","h":"3.62","c":"كَمۡ","d":"kam","e":"(that) how many","i":"كَمۡ"},{"b":"2.2","h":"4.45","c":"أَهۡلَكۡنَا","d":"ahlaknā","e":"We have destroyed","i":"اَهۡلَكۡنَا"},{"b":"3.3","h":"6.53","c":"مِن","d":"min","e":"before them","i":"مِنۡ"},{"b":"4.2","h":"7.69","c":"قَبۡلِهِم","d":"qablihim","e":"before them","i":"قَبۡلِهِمۡ"},{"b":"6.1","h":"9.89","c":"مِّنَ","d":"mina","e":"of","i":"مِّنَ"},{"b":"6.3","h":"10.55","c":"ٱلۡقُرُونِ","d":"l-qurūni","e":"the generations","i":"الۡقُرُوۡنِ"},{"b":"7.3","h":"12.39","c":"يَمۡشُونَ","d":"yamshūna","e":"they walk about","i":"يَمۡشُوۡنَ"},{"b":"8.2","h":"14.32","c":"فِي","d":"fī","e":"in","i":"فِىۡ"},{"b":"8.6","h":"15.18","c":"مَسَٰكِنِهِمۡۚ","d":"masākinihim","e":"their dwellings","i":"مَسٰكِنِهِمۡؕ"},{"b":"10.3","h":"19.65","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"11.5","h":"21.14","c":"فِي","d":"fī","e":"in","i":"فِىۡ"},{"b":"11.9","h":"21.95","c":"ذَٰلِكَ","d":"dhālika","e":"that","i":"ذٰ لِكَ"},{"b":"12.7","h":"23.62","c":"لَأٓيَٰتٍۚ","d":"laāyātin","e":"surely, are Signs","i":"لَاٰيٰتٍؕ"},{"b":"15.5","h":"28","c":"أَفَلَا","d":"afalā