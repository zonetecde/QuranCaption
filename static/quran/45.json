إِلَىٰ","d":"ilā","e":"to","i":"اِلٰى"},{"b":"10.7","h":"18.7","c":"رَبِّكُمۡ","d":"rabbikum","e":"your Lord","i":"رَبِّكُمۡ"},{"b":"11.9","h":"20.81","c":"تُرۡجَعُونَ","d":"tur'jaʿūna","e":"you will be returned","i":"تُرۡجَعُوۡنَ"}],"a":{"g":"Whoever does a good deed - it is for himself; and whoever does evil - it is against the self. Then to your Lord you will be returned."}},"16":{"w":[{"b":"0.03","h":"0.9","c":"وَلَقَدۡ","d":"walaqad","e":"And certainly","i":"وَلَقَدۡ"},{"b":"0.82","h":"2.04","c":"ءَاتَيۡنَا","d":"ātaynā","e":"We gave","i":"اٰتَيۡنَا"},{"b":"2.0","h":"4.29","c":"بَنِيٓ","d":"banī","e":"(the) Children of Israel","i":"بَنِىۡۤ"},{"b":"3.8","h":"6.33","c":"إِسۡرَـٰٓءِيلَ","d":"is'rāīla","e":"(the) Children of Israel","i":"اِسۡرَآءِيۡلَ"},{"b":"6.8","h":"9.68","c":"ٱلۡكِتَٰبَ","d":"l-kitāba","e":"the Book","i":"الۡكِتٰبَ"},{"b":"7.8","h":"11.51","c":"وَٱلۡحُكۡمَ","d":"wal-ḥuk'ma","e":"and the wisdom","i":"وَالۡحُكۡمَ"},{"b":"8.8","h":"13.27","c":"وَٱلنُّبُوَّةَ","d":"wal-nubuwata","e":"and the Prophethood","i":"وَالنُّبُوَّةَ"},{"b":"10.","h":"16.07","c":"وَرَزَقۡنَٰهُم","d":"warazaqnāhum","e":"and We provided them","i":"وَرَزَقۡنٰهُمۡ"},{"b":"13.2","h":"19.38","c":"مِّنَ","d":"mina","e":"of","i":"مِّنَ"},{"b":"13.5","h":"20.02","c":"ٱلطَّيِّبَٰتِ","d":"l-ṭayibāti","e":"the good things","i":"الطَّيِّبٰتِ"},{"b":"20.7","h":"22.7","c":"وَفَضَّلۡنَٰهُمۡ","d":"wafaḍḍalnāhum","e":"and We preferred them","i":"وَفَضَّلۡنٰهُمۡ"},{"b":"22.5","h":"26.24","c":"عَلَى","d":"ʿalā","e":"over","i":"عَلَى"},{"b":"22.9","h":"27.25","c":"ٱلۡعَٰلَمِينَ","d":"l-ʿālamīna","e":"the worlds","i":"الۡعٰلَمِيۡنَۚ"}],"a":{"g":"And We did certainly give the Children of Israel the Scripture and judgement and prophethood, and We provided them with good things and preferred them over the worlds."}},"17":{"w":[{"b":"0.03","h":"0.05","c":"وَءَاتَيۡنَٰهُم","d":"waātaynāhum","e":"And We gave them","i":"وَاٰتَيۡنٰهُمۡ"},{"b":"2.3","h":"3.88","c":"بَيِّنَٰتٖ","d":"bayyinātin","e":"clear proofs","i":"بَيِّنٰتٍ"},{"b":"4.5","h":"7.24","c":"مِّنَ","d":"mina","e":"of","i":"مِّنَ"},{"b":"4.8","h":"7.9","c":"ٱلۡأَمۡرِۖ","d":"l-amri","e":"the matter","i":"الۡاَمۡرِۚ"},{"b":"5.8","h":"11.45","c":"فَمَا","d":"famā","e":"And not","i":"فَمَا"},{"b":"6.1","h":"11.86","c":"ٱخۡتَلَفُوٓاْ","d":"ikh'talafū","e":"they differed","i":"اخۡتَلَفُوۡۤا"},{"b":"8.7","h":"14.74","c":"إِلَّا","d":"illā","e":"except","i":"اِلَّا"},{"b":"9.5","h":"16.25","c":"مِنۢ","d":"min","e":"after","i":"مِنۡۢ"},{"b":"10.5","h":"17.39","c":"بَعۡدِ","d":"baʿdi","e":"after","i":"بَعۡدِ"},{"b":"11.","h":"18.48","c":"مَا","d":"mā","e":"[what]","i":"مَا"},{"b":"11.5","h":"19.25","c":"جَآءَهُمُ","d":"jāahumu","e":"came to them","i":"جَآءَهُمُ"},{"b":"14.3","h":"22.1","c":"ٱلۡعِلۡمُ","d":"l-ʿil'mu","e":"the knowledge","i":"الۡعِلۡمُۙ"},{"b":"15.1","h":"23.64","c":"بَغۡيَۢا","d":"baghyan","e":"(out of) envy","i":"بَغۡيًاۢ"},{"b":"16.7","h":"25.53","c":"بَيۡنَهُمۡۚ","d":"baynahum","e":"between themselves","i":"بَيۡنَهُمۡؕ"},{"b":"18.0","h":"30.6","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"18.9","h":"32.14","c":"رَبَّكَ","d":"rabbaka","e":"your Lord","i":"رَبَّكَ"},{"b":"19.7","h":"33.55","c":"يَقۡضِي","d":"yaqḍī","e":"will judge","i":"يَقۡضِىۡ"},{"b":"20.5","h":"35.11","c":"بَيۡنَهُمۡ","d":"baynahum","e":"between them","i":"بَيۡنَهُمۡ"},{"b":"21.5","h":"36.89","c":"يَوۡمَ","d":"yawma","e":"(on the) Day","i":"يَوۡمَ"},{"b":"22.1","h":"37.96","c":"ٱلۡقِيَٰمَةِ","d":"l-qiyāmati","e":"(of) the Resurrection","i":"الۡقِيٰمَةِ"},{"b":"23.3","h":"40.22","c":"فِيمَا","d":"fīmā","e":"about what","i":"فِيۡمَا"},{"b":"24.1","h":"41.74","c":"كَانُواْ","d":"kānū","e":"they used (to)","i":"كَانُوۡا"},{"b":"24.9","h":"43.32","c":"فِيهِ","d":"fīhi","e":"therein","i":"فِيۡهِ"},{"b":"25.7","h":"44.64","c":"يَخۡتَلِفُونَ","d":"yakhtalifūna","e":"differ","i":"يَخۡتَلِفُوۡنَ"}],"a":{"g":"And We gave them clear proofs of the matter [of religion]. And they did not differ except after knowledge had come to them - out of jealous animosity between themselves. Indeed, your Lord will judge between them on the Day of Resurrection concerning that over which they used to differ."}},"18":{"w":[{"b":"0.05","h":"1.1","c":"ثُمَّ","d":"thumma","e":"Then","i":"ثُمَّ"},{"b":"1.0","h":"2.31","c":"جَعَلۡنَٰكَ","d":"jaʿalnāka","e":"We put you","i":"جَعَلۡنٰكَ"},{"b":"2.3","h":"4.43","c":"عَلَىٰ","d":"ʿalā","e":"on","i":"عَلٰى"},{"b":"2.8","h":"5.64","c":"شَرِيعَةٖ","d":"sharīʿatin","e":"an ordained way","i":"شَرِيۡعَةٍ"},{"b":"4.9","h":"8.32","c":"مِّنَ","d":"mina","e":"of","i":"مِّنَ"},{"b":"5.2","h":"8.89","c":"ٱلۡأَمۡرِ","d":"l-amri","e":"the matter","i":"الۡاَمۡرِ"},{"b":"5.9","h":"10.3","c":"فَٱتَّبِعۡهَا","d":"fa-ittabiʿ'hā","e":"so follow it","i":"فَاتَّبِعۡهَا"},{"b":"7.3","h":"13.18","c":"وَلَا","d":"walā","e":"and (do) not","i":"وَلَا"},{"b":"7.9","h":"14.24","c":"تَتَّبِعۡ","d":"tattabiʿ","e":"follow","i":"تَتَّبِعۡ"},{"b":"9.0","h":"16.07","c":"أَهۡوَآءَ","d":"ahwāa","e":"(the) desires","i":"اَهۡوَآءَ"},{"b":"11.5","h":"19.15","c":"ٱلَّذِينَ","d":"alladhīna","e":"(of) those who","i":"الَّذِيۡنَ"},{"b":"12.6","h":"21.09","c":"لَا","d":"lā","e":"(do) not","i":"لَا"},{"b":"12.9","h":"21.91","c":"يَعۡلَمُونَ","d":"yaʿlamūna","e":"know","i":"يَعۡلَمُوۡنَ"}],"a":{"g":"Then We put you, [O Muhammad], on an ordained way concerning the matter [of religion]; so follow it and do not follow the inclinations of those who do not know."}},"19":{"w":[{"b":"0.03","h":"0.75","c":"إِنَّهُمۡ","d":"innahum","e":"Indeed they","i":"اِنَّهُمۡ"},{"b":"1.6","h":"3.09","c":"لَن","d":"lan","e":"never","i":"لَنۡ"},{"b":"2.7","h":"4.23","c":"يُغۡنُواْ","d":"yugh'nū","e":"will avail","i":"يُّغۡنُوۡا"},{"b":"3.4","h":"5.59","c":"عَنكَ","d":"ʿanka","e":"you","i":"عَنۡكَ"},{"b":"4.8","h":"7.37","c":"مِنَ","d":"mina","e":"against","i":"مِنَ"},{"b":"5.2","h":"8.08","c":"ٱللَّهِ","d":"l-lahi","e":"Allah","i":"اللّٰهِ"},{"b":"6.0","h":"9.64","c":"شَيۡـٔٗاۚ","d":"shayan","e":"(in) anything","i":"شَيۡــًٔـاؕ"},{"b":"7.4","h":"13.97","c":"وَإِنَّ","d":"wa-inna","e":"And indeed","i":"وَ اِنَّ"},{"b":"8.6","h":"15.76","c":"ٱلظَّـٰلِمِينَ","d":"l-ẓālimīna","e":"the wrongdoers","i":"الظّٰلِمِيۡنَ"},{"b":"10.0","h":"18.4","c":"بَعۡضُهُمۡ","d":"baʿḍuhum","e":"some of them","i":"بَعۡضُهُمۡ"},{"b":"11.1","h":"20.23","c":"أَوۡلِيَآءُ","d":"awliyāu","e":"(are) allies","i":"اَوۡلِيَآءُ"},{"b":"13.7","h":"23.53","c":"بَعۡضٖۖ","d":"baʿḍin","e":"(of) others","i":"بَعۡضٍۚ"},{"b":"14.9","h":"26.05","c":"وَٱللَّهُ","d":"wal-lahu","e":"and Allah","i":"وَاللّٰهُ"},{"b":"15.8","h":"27.83","c":"وَلِيُّ","d":"waliyyu","e":"(is the) Protector","i":"وَلِىُّ"},{"b":"16.6","h":"29.47","c":"ٱلۡمُتَّقِينَ","d":"l-mutaqīna","e":"(of) the righteous","i":"الۡمُتَّقِيۡنَ"}],"a":{"g":"Indeed, they will never avail you against Allah at all. And indeed, the wrongdoers are allies of one another; but Allah is the protector of the righteous."}},"20":{"w":[{"b":"0.07","h":"0.9","c":"هَٰذَا","d":"hādhā","e":"This","i":"هٰذَا"},{"b":"0.85","h":"2.57","c":"بَصَـٰٓئِرُ","d":"baṣāiru","e":"(is) enlightenment","i":"بَصَاٮِٕرُ"},{"b":"3.6","h":"5.63","c":"لِلنَّاسِ","d":"lilnnāsi","e":"for mankind","i":"لِلنَّاسِ"},{"b":"5.0","h":"7.79","c":"وَهُدٗى","d":"wahudan","e":"and guidance","i":"وَهُدًى"},{"b":"5.7","h":"8.96","c":"وَرَحۡمَةٞ","d":"waraḥmatun","e":"and mercy","i":"وَّرَحۡمَةٌ"},{"b":"7.2","h":"11.48","c":"لِّقَوۡمٖ","d":"liqawmin","e":"for a people","i":"لِّقَوۡمٍ"},{"b":"9.3","h":"14.24","c":"يُوقِنُونَ","d":"yūqinūna","e":"who are certain","i":"يُّوۡقِنُوۡنَ"}],"a":{"g":"This [Qur'an] is enlightenment for mankind and guidance and mercy for a people who are certain [in faith]."}},"21":{"w":[{"b":"0.04","h":"0.45","c":"أَمۡ","d":"am","e":"Do","i":"اَمۡ"},{"b":"0.31","h":"0.95","c":"حَسِبَ","d":"ḥasiba","e":"think","i":"حَسِبَ"},{"b":"0.96","h":"2.03","c":"ٱلَّذِينَ","d":"alladhīna","e":"those who","i":"الَّذِيۡنَ"},{"b":"1.9","h":"3.73","c":"ٱجۡتَرَحُواْ","d":"ij'taraḥū","e":"commit","i":"اجۡتَـرَحُوا"},{"b":"2.7","h":"5.16","c":"ٱلسَّيِّـَٔاتِ","d":"l-sayiāti","e":"evil deeds","i":"السَّيِّاٰتِ"},{"b":"4.2","h":"7.82","c":"أَن","d":"an","e":"that","i":"اَنۡ"},{"b":"4.3","h":"8.97","c":"نَّجۡعَلَهُمۡ","d":"najʿalahum","e":"We will make them","i":"نَّجۡعَلَهُمۡ"},{"b":"6.2","h":"10.96","c":"كَٱلَّذِينَ","d":"ka-alladhīna","e":"like those","i":"كَالَّذِيۡنَ"},{"b":"7.4","h":"13.14","c":"ءَامَنُواْ","d":"āmanū","e":"who believed","i":"اٰمَنُوۡا"},{"b":"8.4","h":"15.03","c":"وَعَمِلُواْ","d":"waʿamilū","e":"and did","i":"وَعَمِلُوا"},{"b":"9.2","h":"16.33","c":"ٱلصَّـٰلِحَٰتِ","d":"l-ṣāliḥāti","e":"righteous deeds","i":"الصّٰلِحٰتِۙ"},{"b":"10.5","h":"19.07","c":"سَوَآءٗ","d":"sawāan","e":"equal","i":"سَوَآءً"},{"b":"13.8","h":"21.55","c":"مَّحۡيَاهُمۡ","d":"maḥyāhum","e":"(in) their life","i":"مَّحۡيَاهُمۡ"},{"b":"15.0","h":"24.47","c":"وَمَمَاتُهُمۡۚ","d":"wamamātuhum","e":"and their death","i":"وَمَمَاتُهُمۡؕ"},{"b":"17.1","h":"30.9","c":"سَآءَ","d":"sāa","e":"Evil is","i":"سَآءَ"},{"b":"19.2","h":"33.24","c":"مَا","d":"mā","e":"what","i":"مَا"},{"b":"19.","h":"34.11","c":"يَحۡكُمُونَ","d":"yaḥkumūna","e":"they judge","i":"يَحۡكُمُوۡنَ"}],"a":{"g":"Or do those who commit evils think We will make them like those who have believed and done righteous deeds - [make them] equal in their life and their death? Evil is that which they judge."}},"22":{"w":[{"b":"0.03","h":"1","c":"وَخَلَقَ","d":"wakhalaqa","e":"And Allah created","i":"وَ خَلَقَ"},{"b":"0.79","h":"2.41","c":"ٱللَّهُ","d":"l-lahu","e":"And Allah created","i":"اللّٰهُ"},{"b":"1.5","h":"3.91","c":"ٱلسَّمَٰوَٰتِ","d":"l-samāwāti","e":"the heavens","i":"السَّمٰوٰتِ"},{"b":"3.0","h":"6.62","c":"وَٱلۡأَرۡضَ","d":"wal-arḍa","e":"and the earth","i":"وَالۡاَرۡضَ"},{"b":"3.9","h":"8.47","c":"بِٱلۡحَقِّ","d":"bil-ḥaqi","e":"in truth","i":"بِالۡحَقِّ"},{"b":"4.9","h":"10.24","c":"وَلِتُجۡزَىٰ","d":"walituj'zā","e":"and that may be recompensed","i":"وَلِتُجۡزٰى"},{"b":"6.1","h":"12.47","c":"كُلُّ","d":"kullu","e":"every","i":"كُلُّ"},{"b":"6.7","h":"13.68","c":"نَفۡسِۭ","d":"nafsin","e":"soul","i":"نَفۡسٍۢ"},{"b":"7.9","h":"15.61","c":"بِمَا","d":"bimā","e":"for what","i":"بِمَا"},{"b":"8.5","h":"16.75","c":"كَسَبَتۡ","d":"kasabat","e":"it has earned","i":"كَسَبَتۡ"},{"b":"9.3","h":"18.14","c":"وَهُمۡ","d":"wahum","e":"and they","i":"وَهُمۡ"},{"b":"9.9","h":"19.51","c":"لَا","d":"lā","e":"will not be wronged","i":"لَا"},{"b":"10.3","h":"20.39","c":"يُظۡلَمُونَ","d":"yuẓ'lamūna","e":"will not be wronged","i":"يُظۡلَمُوۡنَ"}],"a":{"g":"And Allah created the heavens and earth in truth and so that every soul may be recompensed for what it has earned, and they will not be wronged."}},"23":{"w":[{"b":"0.03","h":"0.65","c":"أَفَرَءَيۡتَ","d":"afara-ayta","e":"Have you seen","i":"اَفَرَءَيۡتَ"},{"b":"1.2","h":"2.64","c":"مَنِ","d":"mani","e":"(he) who","i":"مَنِ"},{"b":"1.6","h":"3.32","c":"ٱتَّخَذَ","d":"ittakhadha","e":"takes","i":"اتَّخَذَ"},{"b":"2.3","h":"4.76","c":"إِلَٰهَهُۥ","d":"ilāhahu","e":"(as) his god","i":"اِلٰهَهٗ"},{"b":"3.5","h":"7.02","c":"هَوَىٰهُ","d":"hawāhu","e":"his desire","i":"هَوٰٮهُ"},{"b":"4.3","h":"8.51","c":"وَأَضَلَّهُ","d":"wa-aḍallahu","e":"and Allah lets him go astray","i":"وَاَضَلَّهُ"},{"b":"5.6","h":"10.69","c":"ٱللَّهُ","d":"l-lahu","e":"and Allah lets him go astray","i":"اللّٰهُ"},{"b":"6.3","h":"12.07","c":"عَلَىٰ","d":"ʿalā","e":"knowingly","i":"عَلٰى"},{"b":"6.9","h":"13.19","c":"عِلۡمٖ","d":"ʿil'min","e":"knowingly","i":"عِلۡمٍ"},{"b":"7.6","h":"15.14","c":"وَخَتَمَ","d":"wakhatama","e":"and He sets a seal","i":"وَّخَتَمَ"},{"b":"8.9","h":"16.44","c":"عَلَىٰ","d":"ʿalā","e":"upon","i":"عَلٰى"},{"b":"9.5","h":"17.68","c":"سَمۡعِهِۦ","d":"samʿihi","e":"his hearing","i":"سَمۡعِهٖ"},{"b":"10.5","h":"19.7","c":"وَقَلۡبِهِۦ","d":"waqalbihi","e":"and his heart","i":"وَقَلۡبِهٖ"},{"b":"15.8","h":"30.58","c":"وَجَعَلَ","d":"wajaʿala","e":"and puts","i":"وَجَعَلَ"},{"b":"16.6","h":"31.88","c":"عَلَىٰ","d":"ʿalā","e":"over","i":"عَلٰى"},{"b":"17.2","h":"33.08","c":"بَصَرِهِۦ","d":"baṣarihi","e":"his vision","i":"بَصَرِهٖ"},{"b":"18.","h":"34.92","c":"غِشَٰوَةٗ","d":"ghishāwatan","e":"a veil","i":"غِشٰوَةًؕ"},{"b":"20.3","h":"37.55","c":"فَمَن","d":"faman","e":"Then who","i":"فَمَنۡ"},{"b":"21.9","h":"39.15","c":"يَهۡدِيهِ","d":"yahdīhi","e":"will guide him","i":"يَّهۡدِيۡهِ"},{"b":"22.","h":"40.89","c":"مِنۢ","d":"min","e":"after","i":"مِنۡۢ"},{"b":"24.0","h":"42.05","c":"بَعۡدِ","d":"baʿdi","e":"after","i":"بَعۡدِ"},{"b":"24.7","h":"43.07","c":"ٱللَّهِۚ","d":"l-lahi","e":"Allah","i":"اللّٰهِؕ"},{"b":"27.5","h":"48.3","c":"أَفَلَا","d":"afalā","e":"Then will not","i":"اَفَلَا"},{"b":"28.2","h":"49.65","c":"تَذَكَّرُونَ","d":"tadhakkarūna","e":"you receive admonition","i":"تَذَكَّرُوۡنَ"}],"a":{"g":"Have you seen he who has taken as his god his [own] desire, and Allah has sent him astray due to knowledge and has set a seal upon his hearing and his heart and put over his vision a veil? So who will guide him after Allah? Then will you not be reminded?"}},"24":{"w":[{"b":"0.03","h":"0.45","c":"وَقَالُواْ","d":"waqālū","e":"And they say","i":"وَقَالُوۡا"},{"b":"1.0","h":"2.18","c":"مَا","d":"mā","e":"Not","i":"مَا"},{"b":"1.4","h":"2.83","c":"هِيَ","d":"hiya","e":"it","i":"هِىَ"},{"b":"1.8","h":"3.53","c":"إِلَّا","d":"illā","e":"(is) but","i":"اِلَّا"},{"b":"2.5","h":"4.94","c":"حَيَاتُنَا","d":"ḥayātunā","e":"our life","i":"حَيَاتُنَا"},{"b":"3.7","h":"6.88","c":"ٱلدُّنۡيَا","d":"l-dun'yā","e":"(of) the world","i":"الدُّنۡيَا"},{"b":"4.8","h":"8.81","c":"نَمُوتُ","d":"namūtu","e":"we die","i":"نَمُوۡتُ"},{"b":"5.6","h":"10.24","c":"وَنَحۡيَا","d":"wanaḥyā","e":"and we live","i":"وَنَحۡيَا"},{"b":"6.6","h":"12.08","c":"وَمَا","d":"wamā","e":"and not","i":"وَمَا"},{"b":"7.2","h":"13.23","c":"يُهۡلِكُنَآ","d":"yuh'likunā","e":"destroys us","i":"يُهۡلِكُنَاۤ"},{"b":"9.3","h":"16.25","c":"إِلَّا","d":"illā","e":"except","i":"اِلَّا"},{"b":"10.","h":"17.36","c":"ٱلدَّهۡرُۚ","d":"l-dahru","e":"the time","i":"الدَّهۡرُؕ"},{"b":"11.9","h":"21.5","c":"وَمَا","d":"wamā","e":"And not","i":"وَمَا"},{"b":"12.5","h":"22.45","c":"لَهُم","d":"lahum","e":"for them","i":"لَهُمۡ"},{"b":"13.8","h":"23.97","c":"بِذَٰلِكَ","d":"bidhālika","e":"of that","i":"بِذٰلِكَ"},{"b":"14.8","h":"25.79","c":"مِنۡ","d":"min","e":"any","i":"مِنۡ"},{"b":"15.2","h":"26.38","c":"عِلۡمٍۖ","d":"ʿil'min","e":"knowledge","i":"عِلۡمٍۚ"},{"b":"16.0","h":"29.95","c":"إِنۡ","d":"in","e":"not","i":"اِنۡ"},{"b":"16.","h":"30.48","c":"هُمۡ","d":"hum","e":"they","i":"هُمۡ"},{"b":"16.8","h":"31.29","c":"إِلَّا","d":"illā","e":"(do) but","i":"اِلَّا"},{"b":"17.6","h":"32.77","c":"يَظُنُّونَ","d":"yaẓunnūna","e":"guess","i":"يَظُنُّوۡنَ"}],"a":{"g":"And they say, \"There is not but our worldly life; we die and live, and nothing destroys us except time.\" And they have of that no knowledge; they are only assuming."}},"25":{"w":[{"b":"0.03","h":"0.5","c":"وَإِذَا","d":"wa-idhā","e":"And when","i":"وَاِذَا"},{"b":"0.76","h":"1.68","c":"تُتۡلَىٰ","d":"tut'lā","e":"are recited","i":"تُتۡلٰى"},{"b":"1.5","h":"3.11","c":"عَلَيۡهِمۡ","d":"ʿalayhim","e":"to them","i":"عَلَيۡهِمۡ"},{"b":"2.6","h":"4.98","c":"ءَايَٰتُنَا","d":"āyātunā","e":"Our Verses","i":"اٰيٰتُنَا"},{"b":"4.0","h":"7.66","c":"بَيِّنَٰتٖ","d":"bayyinātin","e":"clear","i":"بَيِّنٰتٍ"},{"b":"6.0","h":"10.64","c":"مَّا","d":"mā","e":"not","i":"مَّا"},{"b":"6.3","h":"11.3","c":"كَانَ","d":"kāna","e":"is","i":"كَانَ"},{"b":"6.9","h":"12.43","c":"حُجَّتَهُمۡ","d":"ḥujjatahum","e":"their argument","i":"حُجَّتَهُمۡ"},{"b":"8.1","h":"14.64","c":"إِلَّآ","d":"illā","e":"except","i":"اِلَّاۤ"},{"b":"12.3","h":"15.51","c":"أَن","d":"an","e":"that","i":"اَنۡ"},{"b":"15.0","h":"18.11","c":"قَالُواْ","d":"qālū","e":"they say","i":"قَالُوا"},{"b":"15.7","h":"30.79","c":"ٱئۡتُواْ","d":"i'tū","e":"Bring","i":"ائۡتُوۡا"},{"b":"16.2","h":"31.58","c":"بِـَٔابَآئِنَآ","d":"biābāinā","e":"our forefathers","i":"بِاٰبَآٮِٕنَاۤ"},{"b":"19.7","h":"34.64","c":"إِن","d":"in","e":"if","i":"اِنۡ"},{"b":"21.9","h":"37.36","c":"كُنتُمۡ","d":"kuntum","e":"you are","i":"كُنۡتُمۡ"},{"b":"23.5","h":"39.53","c":"صَٰدِقِينَ","d":"ṣādiqīna","e":"truthful","i":"صٰدِقِيۡنَ"}],"a":{"g":"And when Our verses are recited to them as clear evidences, their argument is only that they say, \"Bring [back] our forefathers, if you should be truthful.\""}},"26":{"w":[{"b":"0.07","h":"1.15","c":"قُلِ","d":"quli","e":"Say","i":"قُلِ"},{"b":"0.46","h":"1.65","c":"ٱللَّهُ","d":"l-lahu","e":"Allah","i":"اللّٰهُ"},{"b":"1.2","h":"3.03","c":"يُحۡيِيكُمۡ","d":"yuḥ'yīkum","e":"gives you life","i":"يُحۡيِيۡكُمۡ"},{"b":"2.4","h":"5.2","c":"ثُمَّ","d":"thumma","e":"then","i":"ثُمَّ"},{"b":"3.5","h":"6.75","c":"يُمِيتُكُمۡ","d":"yumītukum","e":"causes you to die","i":"يُمِيۡتُكُمۡ"},{"b":"4.8","h":"8.93","c":"ثُمَّ","d":"thumma","e":"then","i":"ثُمَّ"},{"b":"6","h":"10.39","c":"يَجۡمَعُكُمۡ","d":"yajmaʿukum","e":"He will gather you","i":"يَجۡمَعُكُمۡ"},{"b":"7.2","h":"12.52","c":"إِلَىٰ","d":"ilā","e":"to","i":"اِلٰى"},{"b":"7.8","h":"13.56","c":"يَوۡمِ","d":"yawmi","e":"(the) Day","i":"يَوۡمِ"},{"b":"8.4","h":"14.61","c":"ٱلۡقِيَٰمَةِ","d":"l-qiyāmati","e":"(of) the Resurrection","i":"الۡقِيٰمَةِ"},{"b":"9.7","h":"16.82","c":"لَا","d":"lā","e":"no","i":"لَا"},{"b":"10.","h":"17.47","c":"رَيۡبَ","d":"rayba","e":"doubt","i":"رَيۡبَ"},{"b":"10.7","h":"18.58","c":"فِيهِ","d":"fīhi","e":"about it","i":"فِيۡهِ"},{"b":"11.4","h":"19.8","c":"وَلَٰكِنَّ","d":"walākinna","e":"But","i":"وَلٰكِنَّ"},{"b":"13.3","h":"22.31","c":"أَكۡثَرَ","d":"akthara","e":"most","i":"اَكۡثَرَ"},{"b":"14.1","h":"23.8","c":"ٱلنَّاسِ","d":"l-nāsi","e":"(of) the people","i":"النَّاسِ"},{"b":"15.5","h":"25.88","c":"لَا","d":"lā","e":"(do) not","i":"لَا"},{"b":"15.","h":"26.69","c":"يَعۡلَمُونَ","d":"yaʿlamūna","e":"know","i":"يَعۡلَمُوۡنَ"}],"a":{"g":"Say, \"Allah causes you to live, then causes you to die; then He will assemble you for the Day of Resurrection, about which there is no doubt, but most of the people do not know.\""}},"27":{"w":[{"b":"0.03","h":"0.81","c":"وَلِلَّهِ","d":"walillahi","e":"And for Allah","i":"وَلِلّٰهِ"},{"b":"1.2","h":"2.75","c":"مُلۡكُ","d":"mul'ku","e":"(is the) dominion","i":"مُلۡكُ"},{"b":"1.8","h":"3.74","c":"ٱلسَّمَٰوَٰتِ","d":"l-samāwāti","e":"(of) the heavens","i":"السَّمٰوٰتِ"},{"b":"3.2","h":"6.51","c":"وَٱلۡأَرۡضِۚ","d":"wal-arḍi","e":"and the earth","i":"وَالۡاَرۡضِؕ"},{"b":"4.7","h":"9.85","c":"وَيَوۡمَ","d":"wayawma","e":"and (the) Day","i":"وَيَوۡمَ"},{"b":"5.4","h":"11.1","c":"تَقُومُ","d":"taqūmu","e":"is established","i":"تَقُوۡمُ"},{"b":"6.3","h":"12.67","c":"ٱلسَّاعَةُ","d":"l-sāʿatu","e":"the Hour","i":"السَّاعَةُ"},{"b":"7.3","h":"14.59","c":"يَوۡمَئِذٖ","d":"yawma-idhin","e":"that Day","i":"يَوۡمَٮِٕذٍ"},{"b":"9.4","h":"17.19","c":"يَخۡسَرُ","d":"yakhsaru","e":"will lose","i":"يَّخۡسَرُ"},{"b":"10.1","h":"18.68","c":"ٱلۡمُبۡطِلُونَ","d":"l-mub'ṭilūna","e":"the falsifiers","i":"الۡمُبۡطِلُوۡنَ"}],"a":{"g":"And to Allah belongs the dominion of the heavens and the earth. And the Day the Hour appears - that Day the falsifiers will lose."}},"28":{"w":[{"b":"0.03","h":"0.03","c":"وَتَرَىٰ","d":"watarā","e":"And you will see","i":"وَتَرٰى"},{"b":"0.83","h":"1.37","c":"كُلَّ","d":"kulla","e":"every","i":"كُلَّ"},{"b":"1.3","h":"2.53","c":"أُمَّةٖ","d":"ummatin","e":"nation","i":"اُمَّةٍ"},{"b":"4.0","h":"5.15","c":"جَاثِيَةٗۚ","d":"jāthiyatan","e":"kneeling","i":"جَاثِيَةً​"},{"b":"5.5","h":"9.05","c":"كُلُّ","d":"kullu","e":"Every","i":"كُلُّ"},{"b":"6.8","h":"9.91","c":"أُمَّةٖ","d":"ummatin","e":"nation","i":"اُمَّةٍ"},{"b":"8.1","h":"12.56","c":"تُدۡعَىٰٓ","d":"tud'ʿā","e":"will be called","i":"تُدۡعٰۤى"},{"b":"10.3","h":"14.99","c":"إِلَىٰ","d":"ilā","e":"to","i":"اِلٰى"},{"b":"10.9","h":"16.07","c":"كِتَٰبِهَا","d":"kitābihā","e":"its record","i":"كِتٰبِهَاؕ"},{"b":"11.9","h":"17.99","c":"ٱلۡيَوۡمَ","d":"l-yawma","e":"Today","i":"اَلۡيَوۡمَ"},{"b":"12.7","h":"19.45","c":"تُجۡزَوۡنَ","d":"tuj'zawna","e":"you will be recompensed","i":"تُجۡزَوۡنَ"},{"b":"13.7","h":"21.45","c":"مَا","d":"mā","e":"(for) what","i":"مَا"},{"b":"14.2","h":"22.19","c":"كُنتُمۡ","d":"kuntum","e":"you used (to)","i":"كُنۡتُمۡ"},{"b":"15.6","h":"24.51","c":"تَعۡمَلُونَ","d":"taʿmalūna","e":"do","i":"تَعۡمَلُوۡنَ"}],"a":{"g":"And you will see every nation kneeling [from fear]. Every nation will be called to its record [and told], \"Today you will be recompensed for what you used to do."}},"29":{"w":[{"b":"0.04","h":"0.6","c":"هَٰذَا","d":"hādhā","e":"This","i":"هٰذَا"},{"b":"0.84","h":"1.95","c":"كِتَٰبُنَا","d":"kitābunā","e":"Our Record","i":"كِتٰبُنَا"},{"b":"2.0","h":"4.44","c":"يَنطِقُ","d":"yanṭiqu","e":"speaks","i":"يَنۡطِقُ"},{"b":"3.3","h":"6.27","c":"عَلَيۡكُم","d":"ʿalaykum","e":"about you","i":"عَلَيۡكُمۡ"},{"b":"5.0","h":"8.98","c":"بِٱلۡحَقِّۚ","d":"bil-ḥaqi","e":"in truth","i":"بِالۡحَقِّؕ"},{"b":"6.6","h":"12.6","c":"إِنَّا","d":"innā","e":"Indeed We","i":"اِنَّا"},{"b":"7.9","h":"14.69","c":"كُنَّا","d":"kunnā","e":"[We] used (to)","i":"كُنَّا"},{"b":"9.5","h":"16.8","c":"نَسۡتَنسِخُ","d":"nastansikhu","e":"transcribe","i":"نَسۡتَنۡسِخُ"},{"b":"11.2","h":"19.52","c":"مَا","d":"mā","e":"what","i":"مَا"},{"b":"11.6","h":"20.27","c":"كُنتُمۡ","d":"kuntum","e":"you used (to)","i":"كُنۡتُمۡ"},{"b":"12.9","h":"22.24","c":"تَعۡمَلُونَ","d":"taʿmalūna","e":"do","i":"تَعۡمَلُوۡنَ"}],"a":{"g":"This, Our record, speaks about you in truth. Indeed, We were having transcribed whatever you used to do.\""}},"30":{"w":[{"b":"0.03","h":"0.6","c":"فَأَمَّا","d":"fa-ammā","e":"Then as for","i":"فَاَمَّا"},{"b":"0.47","h":"2.08","c":"ٱلَّذِينَ","d":"alladhīna","e":"those who","i":"الَّذِيۡنَ"},{"b":"2.3","h":"3.95","c":"ءَامَنُواْ","d":"āmanū","e":"believed","i":"اٰمَنُوۡا"},{"b":"3.3","h":"5.86","c":"وَعَمِلُواْ","d":"waʿamilū","e":"and did","i":"وَعَمِلُوا"},{"b":"4.1","h":"7.28","c":"ٱلصَّـٰلِحَٰتِ","d":"l-ṣāliḥāti","e":"[the] righteous deeds","i":"الصّٰلِحٰتِ"},{"b":"5.5","h":"10.05","c":"فَيُدۡخِلُهُمۡ","d":"fayud'khiluhum","e":"w