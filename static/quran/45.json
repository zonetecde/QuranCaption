َّهِ","d":"l-lahi","e":"(of) Allah","i":"اللّٰهِ"},{"b":"2.7","h":"5.3","c":"تُتۡلَىٰ","d":"tut'lā","e":"recited","i":"تُتۡلٰى"},{"b":"3.4","h":"6.66","c":"عَلَيۡهِ","d":"ʿalayhi","e":"to him","i":"عَلَيۡهِ"},{"b":"4.3","h":"8.29","c":"ثُمَّ","d":"thumma","e":"then","i":"ثُمَّ"},{"b":"5.5","h":"9.82","c":"يُصِرُّ","d":"yuṣirru","e":"persists","i":"يُصِرُّ"},{"b":"6.4","h":"11.32","c":"مُسۡتَكۡبِرٗا","d":"mus'takbiran","e":"arrogantly","i":"مُسۡتَكۡبِرًا"},{"b":"8.5","h":"14.13","c":"كَأَن","d":"ka-an","e":"as if","i":"كَاَنۡ"},{"b":"9","h":"14.88","c":"لَّمۡ","d":"lam","e":"not","i":"لَّمۡ"},{"b":"9.6","h":"16","c":"يَسۡمَعۡهَاۖ","d":"yasmaʿhā","e":"he heard them","i":"يَسۡمَعۡهَاۚ"},{"b":"11.4","h":"20.4","c":"فَبَشِّرۡهُ","d":"fabashir'hu","e":"So give him tidings","i":"فَبَشِّرۡهُ"},{"b":"12.6","h":"22.3","c":"بِعَذَابٍ","d":"biʿadhābin","e":"(of) a punishment","i":"بِعَذَابٍ"},{"b":"13.8","h":"24.58","c":"أَلِيمٖ","d":"alīmin","e":"painful","i":"اَ لِيۡمٍ"}],"a":{"g":"Who hears the verses of Allah recited to him, then persists arrogantly as if he had not heard them. So give him tidings of a painful punishment."}},"9":{"w":[{"b":"0.06","h":"0.55","c":"وَإِذَا","d":"wa-idhā","e":"And when","i":"وَاِذَا"},{"b":"0.86","h":"1.98","c":"عَلِمَ","d":"ʿalima","e":"he knows","i":"عَلِمَ"},{"b":"1.5","h":"2.69","c":"مِنۡ","d":"min","e":"of","i":"مِنۡ"},{"b":"1.9","h":"3.65","c":"ءَايَٰتِنَا","d":"āyātinā","e":"Our Verses","i":"اٰيٰتِنَا"},{"b":"3.3","h":"6.4","c":"شَيۡـًٔا","d":"shayan","e":"anything","i":"شَيۡــًٔـا"},{"b":"4.2","h":"7.86","c":"ٱتَّخَذَهَا","d":"ittakhadhahā","e":"he takes them","i":"اۨتَّخَذَهَا"},{"b":"5.4","h":"10.18","c":"هُزُوًاۚ","d":"huzuwan","e":"(in) ridicule","i":"هُزُوًاؕ"},{"b":"6.8","h":"13.4","c":"أُوْلَـٰٓئِكَ","d":"ulāika","e":"Those","i":"اُولٰٓٮِٕكَ"},{"b":"9.4","h":"15.86","c":"لَهُمۡ","d":"lahum","e":"for them","i":"لَهُمۡ"},{"b":"9.9","h":"16.83","c":"عَذَابٞ","d":"ʿadhābun","e":"(is) a punishment","i":"عَذَابٌ"},{"b":"11.8","h":"19.44","c":"مُّهِينٞ","d":"muhīnun","e":"humiliating","i":"مُّهِيۡنٌؕ"}],"a":{"g":"And when he knows anything of Our verses, he takes them in ridicule. Those will have a humiliating punishment."}},"10":{"w":[{"b":"0.12","h":"0.5","c":"مِّن","d":"min","e":"Before them","i":"مِنۡ"},{"b":"1.3","h":"1.44","c":"وَرَآئِهِمۡ","d":"warāihim","e":"Before them","i":"وَّرَآٮِٕهِمۡ"},{"b":"4.1","h":"4.27","c":"جَهَنَّمُۖ","d":"jahannamu","e":"(is) Hell","i":"جَهَنَّمُۚ"},{"b":"6.7","h":"8.7","c":"وَلَا","d":"walā","e":"and not","i":"وَلَا"},{"b":"7.2","h":"9.62","c":"يُغۡنِي","d":"yugh'nī","e":"will avail","i":"يُغۡنِىۡ"},{"b":"8.1","h":"10.95","c":"عَنۡهُم","d":"ʿanhum","e":"them","i":"عَنۡهُمۡ"},{"b":"9.5","h":"13.02","c":"مَّا","d":"mā","e":"what","i":"مَّا"},{"b":"9.8","h":"13.69","c":"كَسَبُواْ","d":"kasabū","e":"they had earned","i":"كَسَبُوۡا"},{"b":"10.","h":"15.13","c":"شَيۡـٔٗا","d":"shayan","e":"anything","i":"شَيۡــًٔـا"},{"b":"11.3","h":"17.64","c":"وَلَا","d":"walā","e":"and not","i":"وَّلَا"},{"b":"12.8","h":"18.18","c":"مَا","d":"mā","e":"what","i":"مَا"},{"b":"12.9","h":"18.49","c":"ٱتَّخَذُواْ","d":"ittakhadhū","e":"they had taken","i":"اتَّخَذُوۡا"},{"b":"14.0","h":"20.48","c":"مِن","d":"min","e":"besides","i":"مِنۡ"},{"b":"15.0","h":"21.63","c":"دُونِ","d":"dūni","e":"besides","i":"دُوۡنِ"},{"b":"15.7","h":"22.78","c":"ٱللَّهِ","d":"l-lahi","e":"Allah","i":"اللّٰهِ"},{"b":"16.5","h":"24.23","c":"أَوۡلِيَآءَۖ","d":"awliyāa","e":"(as) protectors","i":"اَوۡلِيَآءَۚ"},{"b":"19.7","h":"29.75","c":"وَلَهُمۡ","d":"walahum","e":"And for them","i":"وَلَهُمۡ"},{"b":"20.5","h":"30.92","c":"عَذَابٌ","d":"ʿadhābun","e":"(is) a punishment","i":"عَذَابٌ"},{"b":"21.5","h":"32.88","c":"عَظِيمٌ","d":"ʿaẓīmun","e":"great","i":"عَظِيۡمٌؕ"}],"a":{"g":"Before them is Hell, and what they had earned will not avail them at all nor what they had taken besides Allah as allies. And they will have a great punishment."}},"11":{"w":[{"b":"0.08","h":"1.05","c":"هَٰذَا","d":"hādhā","e":"This","i":"هٰذَا"},{"b":"0.9","h":"2.63","c":"هُدٗىۖ","d":"hudan","e":"(is) guidance","i":"هُدًىۚ"},{"b":"2.2","h":"5.6","c":"وَٱلَّذِينَ","d":"wa-alladhīna","e":"And those who","i":"وَالَّذِيۡنَ"},{"b":"3.5","h":"7.33","c":"كَفَرُواْ","d":"kafarū","e":"disbelieve","i":"كَفَرُوۡا"},{"b":"4.3","h":"8.94","c":"بِـَٔايَٰتِ","d":"biāyāti","e":"in (the) Verses","i":"بِاٰيٰتِ"},{"b":"5.5","h":"11.12","c":"رَبِّهِمۡ","d":"rabbihim","e":"(of) their Lord","i":"رَبِّهِمۡ"},{"b":"6.6","h":"12.98","c":"لَهُمۡ","d":"lahum","e":"for them","i":"لَهُمۡ"},{"b":"7.1","h":"13.89","c":"عَذَابٞ","d":"ʿadhābun","e":"(is) a punishment","i":"عَذَابٌ"},{"b":"8.9","h":"16.37","c":"مِّن","d":"min","e":"of","i":"مِّنۡ"},{"b":"9.0","h":"16.71","c":"رِّجۡزٍ","d":"rij'zin","e":"filth","i":"رِّجۡزٍ"},{"b":"10.","h":"18.51","c":"أَلِيمٌ","d":"alīmun","e":"painful","i":"اَلِيۡمٌ"}],"a":{"g":"This [Qur'an] is guidance. And those who have disbelieved in the verses of their Lord will have a painful punishment of foul nature."}},"12":{"w":[{"b":"0.07","h":"0.4","c":"ٱللَّهُ","d":"al-lahu","e":"Allah","i":"۞ اَللّٰهُ"},{"b":"1.0","h":"1.9","c":"ٱلَّذِي","d":"alladhī","e":"(is) the One Who","i":"الَّذِىۡ"},{"b":"1.7","h":"3.28","c":"سَخَّرَ","d":"sakhara","e":"subjected","i":"سَخَّرَ"},{"b":"2.6","h":"4.67","c":"لَكُمُ","d":"lakumu","e":"to you","i":"لَـكُمُ"},{"b":"3.2","h":"5.72","c":"ٱلۡبَحۡرَ","d":"l-baḥra","e":"the sea","i":"الۡبَحۡرَ"},{"b":"4.0","h":"7.15","c":"لِتَجۡرِيَ","d":"litajriya","e":"that may sail","i":"لِتَجۡرِىَ"},{"b":"5.0","h":"8.83","c":"ٱلۡفُلۡكُ","d":"l-ful'ku","e":"the ships","i":"الۡفُلۡكُ"},{"b":"5.8","h":"10.23","c":"فِيهِ","d":"fīhi","e":"therein","i":"فِيۡهِ"},{"b":"6.4","h":"11.36","c":"بِأَمۡرِهِۦ","d":"bi-amrihi","e":"by His Command","i":"بِاَمۡرِهٖ"},{"b":"7.6","h":"13.47","c":"وَلِتَبۡتَغُواْ","d":"walitabtaghū","e":"and that you may seek","i":"وَلِتَبۡتَغُوۡا"},{"b":"10.9","h":"16.11","c":"مِن","d":"min","e":"of","i":"مِنۡ"},{"b":"11.8","h":"17.05","c":"فَضۡلِهِۦ","d":"faḍlihi","e":"His Bounty","i":"فَضۡلِهٖ"},{"b":"12.9","h":"18.92","c":"وَلَعَلَّكُمۡ","d":"walaʿallakum","e":"and that you may","i":"وَلَعَلَّكُمۡ"},{"b":"14.3","h":"21.54","c":"تَشۡكُرُونَ","d":"tashkurūna","e":"give thanks","i":"تَشۡكُرُوۡنَۚ"}],"a":{"g":"It is Allah who subjected to you the sea so that ships may sail upon it by His command and that you may seek of His bounty; and perhaps you will be grateful."}},"13":{"w":[{"b":"0.13","h":"0.4","c":"وَسَخَّرَ","d":"wasakhara","e":"And He has subjected","i":"وَسَخَّرَ"},{"b":"1.1","h":"2.04","c":"لَكُم","d":"lakum","e":"to you","i":"لَـكُمۡ"},{"b":"2.2","h":"3.67","c":"مَّا","d":"mā","e":"whatever","i":"مَّا"},{"b":"2.5","h":"4.27","c":"فِي","d":"fī","e":"(is) in","i":"فِى"},{"b":"2.8","h":"4.67","c":"ٱلسَّمَٰوَٰتِ","d":"l-samāwāti","e":"the heavens","i":"السَّمٰوٰتِ"},{"b":"4.2","h":"7.37","c":"وَمَا","d":"wamā","e":"and whatever","i":"وَمَا"},{"b":"4.8","h":"8.47","c":"فِي","d":"fī","e":"(is) in","i":"فِى"},{"b":"5.0","h":"8.99","c":"ٱلۡأَرۡضِ","d":"l-arḍi","e":"the earth","i":"الۡاَرۡضِ"},{"b":"5.8","h":"10.44","c":"جَمِيعٗا","d":"jamīʿan","e":"all","i":"جَمِيۡعًا"},{"b":"6.7","h":"12.19","c":"مِّنۡهُۚ","d":"min'hu","e":"from Him","i":"مِّنۡهُؕ"},{"b":"8.7","h":"15.8","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"9.9","h":"17.2","c":"فِي","d":"fī","e":"in","i":"فِىۡ"},{"b":"10.3","h":"18.08","c":"ذَٰلِكَ","d":"dhālika","e":"that","i":"ذٰ لِكَ"},{"b":"11.2","h":"19.61","c":"لَأٓيَٰتٖ","d":"laāyātin","e":"surely are Signs","i":"لَاٰيٰتٍ"},{"b":"12.5","h":"22.49","c":"لِّقَوۡمٖ","d":"liqawmin","e":"for a people","i":"لِّقَوۡمٍ"},{"b":"14.4","h":"24.55","c":"يَتَفَكَّرُونَ","d":"yatafakkarūna","e":"who give thought","i":"يَّتَفَكَّرُوۡنَ"}],"a":{"g":"And He has subjected to you whatever is in the heavens and whatever is on the earth - all from Him. Indeed in that are signs for a people who give thought."}},"14":{"w":[{"b":"0.04","h":"0.35","c":"قُل","d":"qul","e":"Say","i":"قُلْ"},{"b":"0.49","h":"0.51","c":