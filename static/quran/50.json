َا","d":"mā","e":"(is) what","i":"مَا"},{"b":"3.9","h":"5.84","c":"لَدَيَّ","d":"ladayya","e":"(is) with me","i":"لَدَىَّ"},{"b":"4.8","h":"7.13","c":"عَتِيدٌ","d":"ʿatīdun","e":"ready","i":"عَتِيۡدٌؕ"}],"a":{"g":"And his companion, [the angel], will say, \"This [record] is what is with me, prepared.\""}},"24":{"w":[{"b":"0.03","h":"1.1","c":"أَلۡقِيَا","d":"alqiyā","e":"Throw","i":"اَلۡقِيَا"},{"b":"1.0","h":"2.73","c":"فِي","d":"fī","e":"into","i":"فِىۡ"},{"b":"1.6","h":"3.52","c":"جَهَنَّمَ","d":"jahannama","e":"Hell","i":"جَهَنَّمَ"},{"b":"3.6","h":"5.49","c":"كُلَّ","d":"kulla","e":"every","i":"كُلَّ"},{"b":"4.3","h":"6.53","c":"كَفَّارٍ","d":"kaffārin","e":"disbeliever","i":"كَفَّارٍ"},{"b":"5.7","h":"8.65","c":"عَنِيدٖ","d":"ʿanīdin","e":"stubborn","i":"عَنِيۡدٍۙ"}],"a":{"g":"[Allah will say], \"Throw into Hell every obstinate disbeliever,"}},"25":{"w":[{"b":"0.08","h":"0.55","c":"مَّنَّاعٖ","d":"mannāʿin","e":"Forbidder","i":"مَّنَّاعٍ"},{"b":"2.0","h":"2.83","c":"لِّلۡخَيۡرِ","d":"lil'khayri","e":"of good","i":"لِّلۡخَيۡرِ"},{"b":"3.4","h":"4.95","c":"مُعۡتَدٖ","d":"muʿ'tadin","e":"transgressor","i":"مُعۡتَدٍ"},{"b":"5.1","h":"7.12","c":"مُّرِيبٍ","d":"murībin","e":"doubter","i":"مُّرِيۡبِۙ"}],"a":{"g":"Preventer of good, aggressor, and doubter,"}},"26":{"w":[{"b":"0.03","h":"0.6","c":"ٱلَّذِي","d":"alladhī","e":"Who","i":"اۨلَّذِىۡ"},{"b":"1.1","h":"2.18","c":"جَعَلَ","d":"jaʿala","e":"made","i":"جَعَلَ"},{"b":"1.8","h":"3.19","c":"مَعَ","d":"maʿa","e":"with","i":"مَعَ"},{"b":"2.3","h":"3.83","c":"ٱللَّهِ","d":"l-lahi","e":"Allah","i":"اللّٰهِ"},{"b":"3.3","h":"5.21","c":"إِلَٰهًا","d":"ilāhan","e":"a god","i":"اِلٰهًا"},{"b":"4.5","h":"6.92","c":"ءَاخَرَ","d":"ākhara","e":"another","i":"اٰخَرَ"},{"b":"5.4","h":"8.46","c":"فَأَلۡقِيَاهُ","d":"fa-alqiyāhu","e":"so throw him","i":"فَاَ لۡقِيٰهُ"},{"b":"7.1","h":"10.88","c":"فِي","d":"fī","e":"in(to)","i":"فِى"},{"b":"7.4","h":"11.29","c":"ٱلۡعَذَابِ","d":"l-ʿadhābi","e":"the punishment","i":"الۡعَذَابِ"},{"b":"8.5","h":"13.02","c":"ٱلشَّدِيدِ","d":"l-shadīdi","e":"the severe","i":"الشَّدِيۡدِ"}],"a":{"g":"Who made [as equal] with Allah another deity; then throw him into the severe punishment.\""}},"27":{"w":[{"b":"0.06","h":"0.85","c":"قَالَ","d":"qāla","e":"Will say","i":"۞ قَالَ"},{"b":"0.73","h":"1.67","c":"قَرِينُهُۥ","d":"qarīnuhu","e":"his companion","i":"قَرِيۡنُهٗ"},{"b":"2.2","h":"3.72","c":"رَبَّنَا","d":"rabbanā","e":"Our Lord","i":"رَبَّنَا"},{"b":"3.3","h":"5.66","c":"مَآ","d":"mā","e":"not","i":"مَاۤ"},{"b":"3.5","h":"5.69","c":"أَطۡغَيۡتُهُۥ","d":"aṭghaytuhu","e":"I made him transgress","i":"اَطۡغَيۡتُهٗ"},{"b":"7.3","h":"9.91","c":"وَلَٰكِن","d":"walākin","e":"but","i":"وَلٰـكِنۡ"},{"b":"9.0","h":"12.06","c":"كَانَ","d":"kāna","e":"he was","i":"كَانَ"},{"b":"9.7","h":"13.2","c":"فِي","d":"fī","e":"in","i":"فِىۡ"},{"b":"10.2","h":"13.96","c":"ضَلَٰلِۭ","d":"ḍalālin","e":"error","i":"ضَلٰلٍۢ"},{"b":"12.3","h":"16.41","c":"بَعِيدٖ","d":"baʿīdin","e":"far","i":"بَعِيۡدٍ"}],"a":{"g":"His [devil] companion will say, \"Our Lord, I did not make him transgress, but he [himself] was in extreme error.\""}},"28":{"w":[{"b":"0.03","h":"0.85","c":"قَالَ","d":"qāla","e":"He will say","i":"قَالَ"},{"b":"0.73","h":"1.79","c":"لَا","d":"lā","e":"(Do) not","i":"لَا"},{"b":"1.1","h":"2.48","c":"تَخۡتَصِمُواْ","d":"takhtaṣimū","e":"dispute","i":"تَخۡتَصِمُوۡا"},{"b":"2.6","h":"4.75","c":"لَدَيَّ","d":"ladayya","e":"(in) My presence","i":"لَدَىَّ"},{"b":"3.6","h":"6.06","c":"وَقَدۡ","d":"waqad","e":"and indeed","i":"وَقَدۡ"},{"b":"4.3","h":"7.02","c":"قَدَّمۡتُ","d":"qaddamtu","e":"I sent forth","i":"قَدَّمۡتُ"},{"b":"5.6","h":"8.85","c":"إِلَيۡكُم","d":"ilaykum","e":"to you","i":"اِلَيۡكُمۡ"},{"b":"7.6","h":"11.05","c":"بِٱلۡوَعِيدِ","d":"bil-waʿīdi","e":"the Warning","i":"بِالۡوَعِيۡدِ"}],"a":{"g":"[Allah] will say, \"Do not dispute before Me, while I had already presented to you the warning."}},"29":{"w":[{"b":"0.1","h":"0.4","c":"مَا","d":"mā","e":"Not","i":"مَا"},{"b":