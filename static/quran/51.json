4","h":"8.41","c":"رَّسُولٍ","d":"rasūlin","e":"Messenger","i":"رَّسُوۡلٍ"},{"b":"8.9","h":"9.85","c":"إِلَّا","d":"illā","e":"but","i":"اِلَّا"},{"b":"9.7","h":"10.71","c":"قَالُواْ","d":"qālū","e":"they said","i":"قَالُوۡا"},{"b":"10.7","h":"11.72","c":"سَاحِرٌ","d":"sāḥirun","e":"A magician","i":"سَاحِرٌ"},{"b":"11.8","h":"12.94","c":"أَوۡ","d":"aw","e":"or","i":"اَوۡ"},{"b":"12.","h":"13.5","c":"مَجۡنُونٌ","d":"majnūnun","e":"a madman","i":"مَجۡنُوۡنٌ​ۚ"}],"a":{"g":"Similarly, there came not to those before them any messenger except that they said, \"A magician or a madman.\""}},"53":{"w":[{"b":"0.03","h":"0.95","c":"أَتَوَاصَوۡاْ","d":"atawāṣaw","e":"Have they transmitted it to them","i":"اَتَوَاصَوۡا"},{"b":"1.3","h":"2.45","c":"بِهِۦۚ","d":"bihi","e":"Have they transmitted it to them","i":"بِهٖ​ۚ"},{"b":"2.3","h":"4.37","c":"بَلۡ","d":"bal","e":"Nay","i":"بَلۡ"},{"b":"2.7","h":"4.8","c":"هُمۡ","d":"hum","e":"they","i":"هُمۡ"},{"b":"3.2","h":"5.29","c":"قَوۡمٞ","d":"qawmun","e":"(are) a people","i":"قَوۡمٌ"},{"b":"5.1","h":"6.81","c":"طَاغُونَ","d":"ṭāghūna","e":"transgressing","i":"طَاغُوۡنَ​ۚ"}],"a":{"g":"Did they suggest it to them? Rather, they [themselves] are a transgressing people."}},"54":{"w":[{"b":"0.03","h":"0.03","c":"فَتَوَلَّ","d":"fatawalla","e":"So turn away","i":"فَتَوَلَّ"},{"b":"0.99","h":"1.11","c":"عَنۡهُمۡ","d":"ʿanhum","e":"from them","i":"عَنۡهُمۡ"},{"b":"1.8","h":"2.08","c":"فَمَآ","d":"famā","e":"for not","i":"فَمَاۤ"},{"b":"2.2","h":"2.54","c":"أَنتَ","d":"anta","e":"you","i":"اَنۡتَ"},{"b":"5.4","h":"5.44","c":"بِمَلُومٖ","d":"bimalūmin","e":"(are) to be blamed","i":"بِمَلُوۡمٍ"}],"a":{"g":"So leave them, [O Muhammad], for you are not to be blamed."}},"55":{"w":[{"b":"0.05","h":"0.35","c":"وَذَكِّرۡ","d":"wadhakkir","e":"And remind","i":"وَّذَكِّرۡ"},{"b":"1.0","h":"1.31","c":"فَإِنَّ","d":"fa-inna","e":"for indeed","i":"فَاِنَّ"},{"b":"2.9","h":"2.6","c":"ٱلذِّكۡرَىٰ","d":"l-dhik'rā","e":"the reminder","i":"الذِّكۡرٰى"},{"b":"4.1","h":"3.82","c":"تَنفَعُ","d":"tanfaʿu","e":"benefits","i":"تَنۡفَعُ"},{"b":"5.9","h":"5.41","c":"ٱلۡمُؤۡمِنِينَ","d":"l-mu'minīna","e":"the believers","i":"الۡمُؤۡمِنِيۡنَ"}],"a":{"g":"And remind, for indeed, the reminder benefits the believers."}},"56":{"w":[{"b":"0.04","h":"0.4","c":"وَمَا","d":"wamā","e":"And not","i":"وَمَا"},{"b":"0.59","h":"0.97","c":"خَلَقۡتُ","d":"khalaqtu","e":"I have created","i":"خَلَقۡتُ"},{"b":"1.5","h":"2.08","c":"ٱلۡجِنَّ","d":"l-jina","e":"the jinn","i":"الۡجِنَّ"},{"b":"3.4","h":"3.49","c":"وَٱلۡإِنسَ","d":"wal-insa","e":"and the mankind","i":"وَالۡاِنۡسَ"},{"b":"5.4","h":"5.2","c":"إِلَّا","d":"illā","e":"except","i":"اِلَّا"},{"b":"6.4","h":"6.27","c":"لِيَعۡبُدُونِ","d":"liyaʿbudūni","e":"that they worship Me","i":"لِيَعۡبُدُوۡنِ"}],"a":{"g":"And I did not create the jinn and mankind except to worship Me."}},"57":{"w":[{"b":"0.03","h":"0.03","c":"مَآ","d":"mā","e":"Not","i":"مَاۤ"},{"b":"1.3","h":"1.74","c":"أُرِيدُ","d":"urīdu","e":"I want","i":"اُرِيۡدُ"},{"b":"3","h":"2.72","c":"مِنۡهُم","d":"min'hum","e":"from them","i":"مِنۡهُمۡ"},{"b":"4.6","h":"4.27","c":"مِّن","d":"min","e":"any","i":"مِّنۡ"},{"b":"4.7","h":"4.39","c":"رِّزۡقٖ","d":"riz'qin","e":"provision","i":"رِّزۡقٍ"},{"b":"6.2","h":"6.14","c":"وَمَآ","d":"wamā","e":"and not","i":"وَّمَاۤ"},{"b":"8.6","h":"7.91","c":"أُرِيدُ","d":"urīdu","e":"I want","i":"اُرِيۡدُ"},{"b":"9.5","h":"8.91","c":"أَن","d":"an","e":"that","i":"اَنۡ"},{"b":"10.7","h":"9.9","c":"يُطۡعِمُونِ","d":"yuṭ'ʿimūni","e":"they (should) feed Me","i":"يُّطۡعِمُوۡنِ"}],"a":{"g":"I do not want from them any provision, nor do I want them to feed Me."}},"58":{"w":[{"b":"0.03","h":"0.03","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"1.4","h":"1.31","c":"ٱللَّهَ","d":"l-laha","e":"Allah","i":"اللّٰهَ"},{"b":"2.3","h":"2.31","c":"هُوَ","d":"huwa","e":"He","i":"هُوَ"},{"b":"2.8","h":"2.82","c":"ٱلرَّزَّاقُ","d":"l-razāqu","e":"(is) the All-Provider","i":"الرَّزَّاقُ"},{"b":"4.2","h":"4.32","c":"ذُو","d":"dhū","e":"Possessor","i":"ذُو"},{"b":"4.4","h":"4.55","c":"ٱلۡقُوَّةِ","d":"l-quwati","e":"(of) Power","i":"الۡقُوَّةِ"},{"b":"5.6","h":"5.64","c":"ٱلۡمَتِينُ","d":"l-matīnu","e":"the Strong","i":"الۡمَتِيۡنُ"}],"a":{"g":"Indeed, it is Allah who is the [continual] Provider, the firm possessor of strength."}},"59":{"w":[{"b":"0.03","h":"0.03","c":"فَإِنَّ","d":"fa-inna","e":"So indeed","i":"فَاِنَّ"},{"b":"1.3","h":"1.28","c":"لِلَّذِينَ","d":"lilladhīna","e":"for those who","i":"لِلَّذِيۡنَ"},{"b":"2.6","h":"2.53","c":"ظَلَمُواْ","d":"ẓalamū","e":"do wrong","i":"ظَلَمُوۡا"},{"b":"3.5","h":"3.54","c":"ذَنُوبٗا","d":"dhanūban","e":"(is) a portion","i":"ذَنُوۡبًا"},{"b":"4.3","h":"5.26","c":"مِّثۡلَ","d":"mith'la","e":"like","i":"مِّثۡلَ"},{"b":"5.8","h":"5.83","c":"ذَنُوبِ","d":"dhanūbi","e":"(the) portion","i":"ذَنُوۡبِ"},{"b":"6.7","h":"6.78","c":"أَصۡحَٰبِهِمۡ","d":"aṣḥābihim","e":"(of) their companions","i":"اَصۡحٰبِهِمۡ"},{"b":"8.3","h":"8.38","c":"فَلَا","d":"falā","e":"so let them not ask Me to hasten","i":"فَلَا"},{"b":"9.0","h":"9.17","c":"يَسۡتَعۡجِلُونِ","d":"yastaʿjilūni","e":"so let them not ask Me to hasten","i":"يَسۡتَعۡجِلُوۡنِ"}],"a":{"g":"And indeed, for those who have wronged is a portion [of punishment] like the portion of their predecessors, so let them not impatiently urge Me."}},"60":{"w":[{"b":"0.07","h":"0.03","c":"فَوَيۡلٞ","d":"fawaylun","e":"Then woe","i":"فَوَيۡلٌ"},{"b":"1.7","h":"1.25","c":"لِّلَّذِينَ","d":"lilladhīna","e":"to those who","i":"لِّـلَّذِيۡنَ"},{"b":"2.5","h":"2.52","c":"كَفَرُواْ","d":"kafarū","e":"disbelieve","i":"كَفَرُوۡا"},{"b":"3.5","h":"3.65","c":"مِن","d":"min","e":"from","i":"مِنۡ"},{"b":"4.9","h":"4.76","c":"يَوۡمِهِمُ","d":"yawmihimu","e":"their Day","i":"يَّوۡمِهِمُ"},{"b":"5.9","h":"5.8","c":"ٱلَّذِي","d":"alladhī","e":"which","i":"الَّذِىۡ"},{"b":"7.0","h":"6.73","c":"يُوعَدُونَ","d":"yūʿadūna","e":"they are promised","i":"يُوۡعَدُوۡنَ"}],"a":{"g":"And woe to those who have disbelieved from their Day which they are promised."}}}