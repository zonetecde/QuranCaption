":"with","i":"مَعَ"},{"b":"25.0","h":"48.58","c":"ٱلدَّـٰخِلِينَ","d":"l-dākhilīna","e":"those who enter","i":"الدّٰخِلِيۡنَ"}],"a":{"g":"Allah presents an example of those who disbelieved: the wife of Noah and the wife of Lot. They were under two of Our righteous servants but betrayed them, so those prophets did not avail them from Allah at all, and it was said, \"Enter the Fire with those who enter.\""}},"11":{"w":[{"b":"0.11","h":"0.35","c":"وَضَرَبَ","d":"waḍaraba","e":"And presents","i":"وَضَرَبَ"},{"b":"0.88","h":"1.48","c":"ٱللَّهُ","d":"l-lahu","e":"Allah","i":"اللّٰهُ"},{"b":"1.7","h":"2.98","c":"مَثَلٗا","d":"mathalan","e":"an example","i":"مَثَلًا"},{"b":"1.9","h":"3.89","c":"لِّلَّذِينَ","d":"lilladhīna","e":"for those who","i":"لِّـلَّذِيۡنَ"},{"b":"3.6","h":"6.21","c":"ءَامَنُواْ","d":"āmanū","e":"believed","i":"اٰمَنُوۡا"},{"b":"4.3","h":"7.49","c":"ٱمۡرَأَتَ","d":"im'ra-ata","e":"(the) wife","i":"امۡرَاَتَ"},{"b":"5.0","h":"8.92","c":"فِرۡعَوۡنَ","d":"fir'ʿawna","e":"(of) Firaun","i":"فِرۡعَوۡنَ​ۘ"},{"b":"6.0","h":"10.68","c":"إِذۡ","d":"idh","e":"when","i":"اِذۡ"},{"b":"6.5","h":"11.19","c":"قَالَتۡ","d":"qālat","e":"she said","i":"قَالَتۡ"},{"b":"7.2","h":"12.76","c":"رَبِّ","d":"rabbi","e":"My Lord","i":"رَبِّ"},{"b":"7.8","h":"13.99","c":"ٱبۡنِ","d":"ib'ni","e":"Build","i":"ابۡنِ"},{"b":"8.2","h":"14.7","c":"لِي","d":"lī","e":"for me","i":"لِىۡ"},{"b":"8.5","h":"15.28","c":"عِندَكَ","d":"ʿindaka","e":"near You","i":"عِنۡدَكَ"},{"b":"10.1","h":"17.16","c":"بَيۡتٗا","d":"baytan","e":"a house","i":"بَيۡتًا"},{"b":"11.8","h":"19.06","c":"فِي","d":"fī","e":"in","i":"فِى"},{"b":"12.0","h":"19.49","c":"ٱلۡجَنَّةِ","d":"l-janati","e":"Paradise","i":"الۡجَـنَّةِ"},{"b":"13.9","h":"36.68","c":"وَنَجِّنِي","d":"wanajjinī","e":"and save me","i":"وَنَجِّنِىۡ"},{"b":"14.8","h":"38.28","c":"مِن","d":"min","e":"from","i":"مِنۡ"},{"b":"17.6","h":"39.84","c":"فِرۡعَوۡنَ","d":"fir'ʿawna","e":"Firaun","i":"فِرۡعَوۡنَ"},{"b":"18.","h":"41.65","c":"وَعَمَلِهِۦ","d":"w