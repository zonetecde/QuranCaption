c":"كَبِيرٖ","d":"kabīrin","e":"great","i":"كَبِيۡرٍ"}],"a":{"g":"They will say,\" Yes, a warner had come to us, but we denied and said, 'Allah has not sent down anything. You are not but in great error.'\""}},"10":{"w":[{"b":"0.15","h":"0.36","c":"وَقَالُواْ","d":"waqālū","e":"And they will say","i":"وَقَالُوۡا"},{"b":"1.0","h":"2.15","c":"لَوۡ","d":"law","e":"If","i":"لَوۡ"},{"b":"1.3","h":"2.87","c":"كُنَّا","d":"kunnā","e":"we had","i":"كُنَّا"},{"b":"3.2","h":"4.69","c":"نَسۡمَعُ","d":"nasmaʿu","e":"listened","i":"نَسۡمَعُ"},{"b":"4.0","h":"6.04","c":"أَوۡ","d":"aw","e":"or","i":"اَوۡ"},{"b":"4.4","h":"6.74","c":"نَعۡقِلُ","d":"naʿqilu","e":"reasoned","i":"نَعۡقِلُ"},{"b":"5.2","h":"8.25","c":"مَا","d":"mā","e":"not","i":"مَا"},{"b":"5.5","h":"8.96","c":"كُنَّا","d":"kunnā","e":"we (would) have been","i":"كُنَّا"},{"b":"7.0","h":"10.9","c":"فِيٓ","d":"fī","e":"among","i":"فِىۡۤ"},{"b":"8.8","h":"12.59","c":"أَصۡحَٰبِ","d":"aṣḥābi","e":"(the) companions","i":"اَصۡحٰبِ"},{"b":"9.7","h":"14.4","c":"ٱلسَّعِيرِ","d":"l-saʿīri","e":"(of) the Blaze","i":"السَّعِيۡرِ"}],"a":{"g":"And they will say, \"If only we had been listening or reasoning, we would not be among the companions of the Blaze.\""}},"11":{"w":[{"b":"0.03","h":"0.45","c":"فَٱعۡتَرَفُواْ","d":"fa-iʿ'tarafū","e":"Then they (will) confess","i":"فَاعۡتَرَفُوۡا"},{"b":"1.2","h":"2.6","c":"بِذَنۢبِهِمۡ","d":"bidhanbihim","e":"their sins","i":"بِذَنۡۢبِهِمۡ​ۚ"},{"b":"3.1","h":"5.15","c":"فَسُحۡقٗا","d":"fasuḥ'qan","e":"so away with","i":"فَسُحۡقًا"},{"b":"3.9","h":"6.39","c":"لِّأَصۡحَٰبِ","d":"li-aṣḥābi","e":"(the) companions","i":"لِّاَصۡحٰبِ"},{"b":"5.4","h":"9.09","c":"ٱلسَّعِيرِ","d":"l-saʿīri","e":"(of) the Blaze","i":"السَّعِيۡرِ"}],"a":{"g":"And they will admit their sin, so [it is] alienation for the companions of the Blaze."}},"12":{"w":[{"b":"0.03","h":"0.9","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"1.2","h":"2.21","c":"ٱلَّذِينَ","d":"alladhīna","e":"those who","i":"الَّذِيۡنَ"},{"b":"2.2","h":"3.99","c":"يَخۡشَوۡنَ","d":"yakhshawna","e":"fear","i":"يَخۡشَوۡنَ"},{"b":"3.2","h":"5.66","c":"رَبَّهُم","d":"rabbahum","e":"their Lord","i":"رَبَّهُمۡ"},{"b":"4.9","h":"7.9","c":"بِٱلۡغَيۡبِ","d":"bil-ghaybi","e":"unseen","i":"بِالۡغَيۡبِ"},{"b":"5.9","h":"9.55","c":"لَهُم","d":"lahum","e":"for them","i":"لَهُمۡ"},{"b":"7.3","h":"11.09","c":"مَّغۡفِرَةٞ","d":"maghfiratun","e":"(is) forgiveness","i":"مَّغۡفِرَةٌ"},{"b":"8.3","h":"13.58","c":"وَأَجۡرٞ","d":"wa-ajrun","e":"and a reward","i":"وَّاَجۡرٌ"},{"b":"10.9","h":"15.67","c":"كَبِيرٞ","d":"kabīrun","e":"great","i":"كَبِيۡرٌ"}],"a":{"g":"Indeed, those who fear their Lord unseen will have forgiveness and great reward."}},"13":{"w":[{"b":"0.05","h":"0.55","c":"وَأَسِرُّواْ","d":"wa-asirrū","e":"And conceal","i":"وَاَسِرُّوۡا"},{"b":"1.2","h":"2.74","c":"قَوۡلَكُمۡ","d":"qawlakum","e":"your speech","i":"قَوۡلَـكُمۡ"},{"b":"2.2","h":"4.47","c":"أَوِ","d":"awi","e":"or","i":"اَوِ"},{"b":"2.5","h":"5.22","c":"ٱجۡهَرُواْ","d":"ij'harū","e":"proclaim","i":"اجۡهَرُوۡا"},{"b":"3.4","h":"6.78","c":"بِهِۦٓۖ","d":"bihi","e":"it","i":"بِهٖؕ"},{"b":"5.6","h":"8.85","c":"إِنَّهُۥ","d":"innahu","e":"Indeed He","i":"اِنَّهٗ"},{"b":"7.2","h":"10.72","c":"عَلِيمُۢ","d":"ʿalīmun","e":"(is the) All-Knower","i":"عَلِيۡمٌۢ"},{"b":"9.2","h":"13","c":"بِذَاتِ","d":"bidhāti","e":"of what (is in)","i":"بِذَاتِ"},{"b":"9.9","h":"14.45","c":"ٱلصُّدُورِ","d":"l-ṣudūri","e":"the breasts","i":"الصُّدُوۡرِ"}],"a":{"g":"And conceal your speech or publicize it; indeed, He is Knowing of that within the breasts."}},"14":{"w":[{"b":"0.07","h":"0.55","c":"أَلَا","d":"alā","e":"Does not","i":"اَلَا"},{"b":"0.58","h":"1.44","c":"يَعۡلَمُ","d":"yaʿlamu","e":"know","i":"يَعۡلَمُ"},{"b":"1.5","h":"2.94","c":"مَنۡ","d":"man","e":"(the One) Who","i":"مَنۡ"},{"b":"1.7","h":"3.43","c":"خَلَقَ","d":"khalaqa","e":"created","i":"خَلَقَؕ"},{"b":"2.5","h":"4.62","c":"وَهُوَ","d":"wahuwa","e":"And He","i":"وَهُوَ"},{"b":"3.0","h":"5.68","c":"ٱللَّطِيفُ","d":"l-laṭīfu","e":"(is) the Subtle","i":"اللَّطِيۡفُ"},{"b":"4.1","h":"7.66","c":"ٱلۡخَبِيرُ","d":"l-khabīru","e":"the All-Aware","i":"الۡخَبِيۡرُ"}],"a":{"g":"Does He who created not know, while He is the Subtle, the Acquainted?"}},"15":{"w":[{"b":"0.04","h":"0.65","c":"هُوَ","d":"huwa","e":"He","i":"هُوَ"},{"b":"0.36","h":"1.15","c":"ٱلَّذِي","d":"alladhī","e":"(is) the One Who","i":"الَّذِىۡ"},{"b":"1.1","h":"2.59","c":"جَعَلَ","d":"jaʿala","e":"made","i":"جَعَلَ"},{"b":"1.8","h":"3.64","c":"لَكُمُ","d":"lakumu","e":"for you","i":"لَـكُمُ"},{"b":"2.3","h":"4.75","c":"ٱلۡأَرۡضَ","d":"l-arḍa","e":"the earth","i":"الۡاَرۡضَ"},{"b":"3.1","h":"6.21","c":"ذَلُولٗا","d":"dhalūlan","e":"subservient","i":"ذَلُوۡلًا"},{"b":"4.7","h":"8.38","c":"فَٱمۡشُواْ","d":"fa-im'shū","e":"so walk","i":"فَامۡشُوۡا"},{"b":"5.5","h":"9.97","c":"فِي","d":"fī","e":"in","i":"فِىۡ"},{"b":"5.9","h":"10.72","c":"مَنَاكِبِهَا","d":"manākibihā","e":"(the) paths thereof","i":"مَنَاكِبِهَا"},{"b":"7.3","h":"13.24","c":"وَكُلُواْ","d":"wakulū","e":"and eat","i":"وَكُلُوۡا"},{"b":"8.2","h":"14.8","c":"مِن","d":"min","e":"of","i":"مِنۡ"},{"b":"8.4","h":"15.06","c":"رِّزۡقِهِۦۖ","d":"riz'qihi","e":"His provision","i":"رِّزۡقِهٖ​ؕ"},{"b":"9.9","h":"18.2","c":"وَإِلَيۡهِ","d":"wa-ilayhi","e":"and to Him","i":"وَاِلَيۡهِ"},{"b":"11","h":"20.06","c":"ٱلنُّشُورُ","d":"l-nushūru","e":"(is) the Resurrection","i":"النُّشُوۡرُ"}],"a":{"g":"It is He who made the earth tame for you - so walk among its slopes and eat of His provision - and to Him is the resurrection."}},"16":{"w":[{"b":"0.03","h":"0.3","c":"ءَأَمِنتُم","d":"a-amintum","e":"Do you feel secure","i":"ءَاَمِنۡتُمۡ"},{"b":"2.6","h":"3.34","c":"مَّن","d":"man","e":"(from Him) Who","i":"مَّنۡ"},{"b":"3.5","h":"4.56","c":"فِي","d":"fī","e":"(is) in","i":"فِىۡ"},{"b":"3.7","h":"4.94","c":"ٱلسَّمَآءِ","d":"l-samāi","e":"the heaven","i":"السَّمَآءِ"},{"b":"6.0","h":"7.51","c":"أَن","d":"an","e":"not","i":"اَنۡ"},{"b":"7.1","h":"8.59","c":"يَخۡسِفَ","d":"yakhsifa","e":"He will cause to swallow","i":"يَّخۡسِفَ"},{"b":"7.7","h":"9.89","c":"بِكُمُ","d":"bikumu","e":"you","i":"بِكُمُ"},{"b":"8.3","h":"10.95","c":"ٱلۡأَرۡضَ","d":"l-arḍa","e":"the earth","i":"الۡاَرۡضَ"},{"b":"9.1","h":"12.31","c":"فَإِذَا","d":"fa-idhā","e":"when","i":"فَاِذَا"},{"b":"9.9","h":"13.92","c":"هِيَ","d":"hiya","e":"it","i":"هِىَ"},{"b":"10.3","h":"14.61","c":"تَمُورُ","d":"tamūru","e":"sways","i":"تَمُوۡرُۙ"}],"a":{"g":"Do you feel secure that He who [holds authority] in the heaven would not cause the earth to swallow you and suddenly it would sway?"}},"17":{"w":[{"b":"0.04","h":"0.65","c":"أَمۡ","d":"am","e":"Or","i":"اَمۡ"},{"b":"0.37","h":"1.19","c":"أَمِنتُم","d":"amintum","e":"do you feel secure","i":"اَمِنۡتُمۡ"},{"b":"2.8","h":"3.89","c":"مَّن","d":"man","e":"(from Him) Who","i":"مَّنۡ"},{"b":"3.9","h":"5.11","c":"فِي","d":"fī","e":"(is) in","i":"فِى"},{"b":"4.1","h":"5.47","c":"ٱلسَّمَآءِ","d":"l-samāi","e":"the heaven","i":"السَّمَآءِ"},{"b":"6.6","h":"8.08","c":"أَن","d":"an","e":"not","i":"اَنۡ"},{"b":"7.5","h":"9.31","c":"يُرۡسِلَ","d":"yur'sila","e":"He will send","i":"يُّرۡسِلَ"},{"b":"8.1","h":"10.26","c":"عَلَيۡكُمۡ","d":"ʿalaykum","e":"against you","i":"عَلَيۡكُمۡ"},{"b":"9.2","h":"12.4","c":"حَاصِبٗاۖ","d":"ḥāṣiban","e":"a storm of stones","i":"حَاصِبًا​ ؕ"},{"b":"11.0","h":"15.9","c":"فَسَتَعۡلَمُونَ","d":"fasataʿlamūna","e":"Then you would know","i":"فَسَتَعۡلَمُوۡنَ"},{"b":"12.6","h":"18.68","c":"كَيۡفَ","d":"kayfa","e":"how","i":"كَيۡفَ"},{"b":"13.2","h":"20.04","c":"نَذِيرِ","d":"nadhīri","e":"(was) My warning","i":"نَذِيۡرِ"}],"a":{"g":"Or do you feel secure that He who [holds authority] in the heaven would not send against you a storm of stones? Then you would know how [severe] was My warning."}},"18":{"w":[{"b":"0.04","h":"0.91","c":"وَلَقَدۡ","d":"walaqad","e":"And indeed","i":"وَلَـقَدۡ"},{"b":"0.78","h":"2.07","c":"كَذَّبَ","d":"kadhaba","e":"denied","i":"كَذَّبَ"},{"b":"1.5","h":"3.54","c":"ٱلَّذِينَ","d":"allad