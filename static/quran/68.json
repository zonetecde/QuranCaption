na","e":"so they would compromise","i":"فَيُدۡهِنُوۡنَ"}],"a":{"g":"They wish that you would soften [in your position], so they would soften [toward you]."}},"10":{"w":[{"b":"0.03","h":"1","c":"وَلَا","d":"walā","e":"And (do) not","i":"وَلَا"},{"b":"0.51","h":"1.88","c":"تُطِعۡ","d":"tuṭiʿ","e":"obey","i":"تُطِعۡ"},{"b":"1.1","h":"2.98","c":"كُلَّ","d":"kulla","e":"every","i":"كُلَّ"},{"b":"1.7","h":"4.05","c":"حَلَّافٖ","d":"ḥallāfin","e":"habitual swearer","i":"حَلَّافٍ"},{"b":"4","h":"7.13","c":"مَّهِينٍ","d":"mahīnin","e":"worthless","i":"مَّهِيۡنٍۙ"}],"a":{"g":"And do not obey every worthless habitual swearer"}},"11":{"w":[{"b":"0.05","h":"0.85","c":"هَمَّازٖ","d":"hammāzin","e":"Defamer","i":"هَمَّازٍ"},{"b":"2.9","h":"3.99","c":"مَّشَّآءِۭ","d":"mashāin","e":"going about","i":"مَّشَّآءٍۢ"},{"b":"6.3","h":"7.47","c":"بِنَمِيمٖ","d":"binamīmin","e":"with malicious gossip","i":"بِنَمِيۡمٍۙ"}],"a":{"g":"[And] scorner, going about with malicious gossip -"}},"12":{"w":[{"b":"0.04","h":"0.6","c":"مَّنَّاعٖ","d":"mannāʿin","e":"A preventer","i":"مَّنَّاعٍ"},{"b":"1.7","h":"2.97","c":"لِّلۡخَيۡرِ","d":"lil'khayri","e":"of (the) good","i":"لِّلۡخَيۡرِ"},{"b":"2.9","h":"5.2","c":"مُعۡتَدٍ","d":"muʿ'tadin","e":"transgressor","i":"مُعۡتَدٍ"},{"b":"3.9","h":"7.03","c":"أَثِيمٍ","d":"athīmin","e":"sinful","i":"اَثِيۡمٍۙ"}],"a":{"g":"A preventer of good, transgressing and sinful,"}},"13":{"w":[{"b":"0.07","h":"0.9","c":"عُتُلِّۭ","d":"ʿutullin","e":"Cruel","i":"عُتُلٍّ ۢ"},{"b":"1.7","h":"2.9","c":"بَعۡدَ","d":"baʿda","e":"after","i":"بَعۡدَ"},{"b":"2.3","h":"3.98","c":"ذَٰلِكَ","d":"dhālika","e":"(all) that","i":"ذٰلِكَ"},{"b":"3.1","h":"5.5","c":"زَنِيمٍ","d":"zanīmin","e":"utterly useless","i":"زَنِيۡمٍۙ"}],"a":{"g":"Cruel, moreover, and an illegitimate pretender."}},"14":{"w":[{"b":"0.15","h":"0.7","c":"أَن","d":"an","e":"Because","i":"اَنۡ"},{"b":"1.3","h":"1.7","c":"كَانَ","d":"kāna","e":"(he) is","i":"كَانَ"},{"b":"1.9","h":"2.95","c":"ذَا","d":"dhā","e":"a possessor","i":"ذَا"},{"b":"2.4","h":"3.74","c":"مَالٖ","d":"mālin","e":"(of) wealth","i":"مَالٍ"},{"b":"3.0","h":"5.55","c":"وَبَنِينَ","d":"wabanīna","e":"and children","i":"وَّبَنِيۡنَؕ"}],"a":{"g":"Because he is a possessor of wealth and children,"}},"15":{"w":[{"b":"0.03","h":"0.5","c":"إِذَا","d":"idhā","e":"When","i":"اِذَا"},{"b":"0.55","h":"1.34","c":"تُتۡلَىٰ","d":"tut'lā","e":"are recited","i":"تُتۡلٰى"},{"b":"1.3","h":"2.74","c":"عَلَيۡهِ","d":"ʿalayhi","e":"to him","i":"عَلَيۡهِ"},{"b":"2.2","h":"4.27","c":"ءَايَٰتُنَا","d":"āyātunā","e":"Our Verses","i":"اٰيٰتُنَا"},{"b":"3.6","h":"6.84","c":"قَالَ","d":"qāla","e":"he says","i":"قَالَ"},{"b":"4.3","h":"8.03","c":"أَسَٰطِيرُ","d":"asāṭīru","e":"Stories","i":"اَسَاطِيۡرُ"},{"b":"5.5","h":"10.52","c":"ٱلۡأَوَّلِينَ","d":"l-awalīna","e":"(of) the former (people)","i":"الۡاَوَّلِيۡنَ"}],"a":{"g":"When Our verses are recited to him, he says, \"Legends of the former peoples.\""}},"16":{"w":[{"b":"0.03","h":"0.5","c":"سَنَسِمُهُۥ","d":"sanasimuhu","e":"We will brand him","i":"سَنَسِمُهٗ"},{"b":"1.1","h":"2.36","c":"عَلَى","d":"ʿalā","e":"on","i":"عَلَى"},{"b":"1.6","h":"3.18","c":"ٱلۡخُرۡطُومِ","d":"l-khur'ṭūmi","e":"the snout","i":"الۡخُـرۡطُوۡمِ"}],"a":{"g":"We will brand him upon the snout."}},"17":{"w":[{"b":"0.03","h":"0.9","c":"إِنَّا","d":"innā","e":"Indeed We","i":"اِنَّا"},{"b":"1.4","h":"2.65","c":"بَلَوۡنَٰهُمۡ","d":"balawnāhum","e":"have tried them","i":"بَلَوۡنٰهُمۡ"},{"b":"2.8","h":"4.98","c":"كَمَا","d":"kamā","e":"as","i":"كَمَا"},{"b":"3.4","h":"6.16","c":"بَلَوۡنَآ","d":"balawnā","e":"We tried","i":"بَلَوۡنَاۤ"},{"b":"5.6","h":"7.39","c":"أَصۡحَٰبَ","d":"aṣḥāba","e":"(the) companions","i":"اَصۡحٰبَ"},{"b":"6.6","h":"10.65","c":"ٱلۡجَنَّةِ","d":"l-janati","e":"(of) the garden","i":"الۡجَـنَّةِ​ ۚ"},{"b":"8.2","h":"12.88","c":"إِذۡ","d":"idh","e":"when","i":"اِذۡ"},{"b":"8.6","h":"13.44","c":"أَقۡسَمُواْ","d":"aqsamū","e":"they swore","i":"اَقۡسَمُوۡا"},{"b":"9.6","h":"15.61","c":"لَيَصۡرِمُنَّهَا","d