":"1.35","c":"قَالَ","d":"qāla","e":"Said","i":"قَالَ"},{"b":"0.59","h":"1.94","c":"نُوحٞ","d":"nūḥun","e":"Nuh","i":"نُوۡحٌ"},{"b":"1.1","h":"2.91","c":"رَّبِّ","d":"rabbi","e":"My Lord!","i":"رَّبِّ"},{"b":"1.9","h":"4.21","c":"إِنَّهُمۡ","d":"innahum","e":"Indeed they","i":"اِنَّهُمۡ"},{"b":"3.4","h":"6.04","c":"عَصَوۡنِي","d":"ʿaṣawnī","e":"disobeyed me","i":"عَصَوۡنِىۡ"},{"b":"4.5","h":"7.77","c":"وَٱتَّبَعُواْ","d":"wa-ittabaʿū","e":"and followed","i":"وَاتَّبَعُوۡا"},{"b":"5.6","h":"9.59","c":"مَن","d":"man","e":"(the one) who","i":"مَنۡ"},{"b":"5.8","h":"9.91","c":"لَّمۡ","d":"lam","e":"(did) not","i":"لَّمۡ"},{"b":"6.3","h":"10.79","c":"يَزِدۡهُ","d":"yazid'hu","e":"increase him","i":"يَزِدۡهُ"},{"b":"7.1","h":"12.03","c":"مَالُهُۥ","d":"māluhu","e":"his wealth","i":"مَالُهٗ"},{"b":"8.1","h":"13.6","c":"وَوَلَدُهُۥٓ","d":"wawaladuhu","e":"and his children","i":"وَوَلَدُهٗۤ"},{"b":"10.7","h":"16.52","c":"إِلَّا","d":"illā","e":"except","i":"اِلَّا"},{"b":"11.3","h":"17.62","c":"خَسَارٗا","d":"khasāran","e":"(in) loss","i":"خَسَارًا​ ۚ"}],"a":{"g":"Noah said, \"My Lord, indeed they have disobeyed me and followed him whose wealth and children will not increase him except in loss."}},"22":{"w":[{"b":"0.03","h":"0.55","c":"وَمَكَرُواْ","d":"wamakarū","e":"And they have planned","i":"وَمَكَرُوۡا"},{"b":"0.98","h":"2.03","c":"مَكۡرٗا","d":"makran","e":"a plan","i":"مَكۡرًا"},{"b":"2.4","h":"3.73","c":"كُبَّارٗا","d":"kubbāran","e":"great","i":"كُبَّارًا​ ۚ"}],"a":{"g":"And they conspired an immense conspiracy."}},"23":{"w":[{"b":"0.03","h":"0.2","c":"وَقَالُواْ","d":"waqālū","e":"And they said","i":"وَ قَالُوۡا"},{"b":"0.94","h":"1.73","c":"لَا","d":"lā","e":"(Do) not","i":"لَا"},{"b":"1.2","h":"2.2","c":"تَذَرُنَّ","d":"tadharunna","e":"leave","i":"تَذَرُنَّ"},{"b":"2.8","h":"4.08","c":"ءَالِهَتَكُمۡ","d":"ālihatakum","e":"your gods","i":"اٰلِهَتَكُمۡ"},{"b":"4.1","h":"6.2","c":"وَلَا","d":"walā","e":"and (do) not","i":"وَلَا"},{"b":"4.6","h":"7.11","c":"تَذَرُنَّ","d":"tadharunna","e":"leave","i":"تَذَرُنَّ"},{"b":"6.1","h":"8.98","c":"وَدّٗا","d":"waddan","e":"Wadd","i":"وَدًّا"},{"b":"6.7","h":"9.99","c":"وَلَا","d":"walā","e":"and not","i":"وَّلَا"},{"b":"7.8","h":"11.52","c":"سُوَاعٗا","d":"suwāʿan","e":"Suwa","i":"سُوَاعًا  ۙ"},{"b":"8.7","h":"13.04","c":"وَلَا","d":"walā","e":"and not","i":"وَّ لَا"},{"b":"9.9","h":"14.65","c":"يَغُوثَ","d":"yaghūtha","e":"Yaguth","i":"يَغُوۡثَ"},{"b":"10.8","h":"15.93","c":"وَيَعُوقَ","d":"wayaʿūqa","e":"and Yauq","i":"وَيَعُوۡقَ"},{"b":"11.7","h":"17.61","c":"وَنَسۡرٗا","d":"wanasran","e":"and Nasr","i":"وَنَسۡرًا​ ۚ"}],"a":{"g":"And said, 'Never leave your gods and never leave Wadd or Suwa' or Yaghuth and Ya'uq and Nasr."}},"24":{"w":[{"b":"0.03","h":"1","c":"وَقَدۡ","d":"waqad","e":"And indeed","i":"وَقَدۡ"},{"b":"0.53","h":"1.77","c":"أَضَلُّواْ","d":"aḍallū","e":"they have led astray","i":"اَضَلُّوۡا"},{"b":"1.4","h":"3.26","c":"كَثِيرٗاۖ","d":"kathīran","e":"many","i":"كَثِيۡرًا​ ​ ۚ"},{"b":"2.9","h":"6.3","c":"وَلَا","d":"walā","e":"And not","i":"وَلَا"},{"b":"3.5","h":"6.97","c":"تَزِدِ","d":"tazidi","e":"increase","i":"تَزِدِ"},{"b":"4.1","h":"7.86","c":"ٱلظَّـٰلِمِينَ","d":"l-ẓālimīna","e":"the wrongdoers","i":"الظّٰلِمِيۡنَ"},{"b":"5.5","h":"10.24","c":"إِلَّا","d":"illā","e":"except","i":"اِلَّا"},{"b":"6.2","h":"11.45","c":"ضَلَٰلٗا","d":"ḍalālan","e":"(in) error","i":"ضَلٰلًا"}],"a":{"g":"And already they have misled many. And, [my Lord], do not increase the wrongdoers except in error.\""}},"25":{"w":[{"b":"0.04","h":"1.76","c":"مِّمَّا","d":"mimmā","e":"Because of","i":"مِّمَّا"},{"b":"1.6","h":"2.28","c":"خَطِيٓـَٰٔتِهِمۡ","d":"khaṭīātihim","e":"their sins","i":"خَطِٓيْئٰتِهِمۡ"},{"b":"4.8","h":"5.94","c":"أُغۡرِقُواْ","d":"ugh'riqū","e":"they were drowned","i":"اُغۡرِقُوۡا"},{"b":"5.7","h":"7.44","c":"فَأُدۡخِلُواْ","d":"fa-ud'khilū","e":"then made to enter","i":"فَاُدۡخِلُوۡا"},{"b":"6.9","h":"9.25","c":"نَارٗا","d":"nāran","e":"(the) Fire","i":"نَارًا  ۙ"},{"b"