9","c":"لَّن","d":"lan","e":"never","i":"لَّنۡ"},{"b":"6.5","h":"9.77","c":"يَبۡعَثَ","d":"yabʿatha","e":"will raise","i":"يَّبۡعَثَ"},{"b":"7.2","h":"10.97","c":"ٱللَّهُ","d":"l-lahu","e":"Allah","i":"اللّٰهُ"},{"b":"8.0","h":"12.09","c":"أَحَدٗا","d":"aḥadan","e":"anyone","i":"اَحَدًاۙ"}],"a":{"g":"And they had thought, as you thought, that Allah would never send anyone [as a messenger]."}},"8":{"w":[{"b":"0.03","h":"0.5","c":"وَأَنَّا","d":"wa-annā","e":"And that we","i":"وَّاَنَّا"},{"b":"1.4","h":"2.58","c":"لَمَسۡنَا","d":"lamasnā","e":"sought to touch","i":"لَمَسۡنَا"},{"b":"2.2","h":"3.88","c":"ٱلسَّمَآءَ","d":"l-samāa","e":"the heaven","i":"السَّمَآءَ"},{"b":"4.5","h":"6.21","c":"فَوَجَدۡنَٰهَا","d":"fawajadnāhā","e":"but we found it","i":"فَوَجَدۡنٰهَا"},{"b":"6.0","h":"8.94","c":"مُلِئَتۡ","d":"muli-at","e":"filled (with)","i":"مُلِئَتۡ"},{"b":"6.7","h":"9.99","c":"حَرَسٗا","d":"ḥarasan","e":"guards","i":"حَرَسًا"},{"b":"8.1","h":"11.79","c":"شَدِيدٗا","d":"shadīdan","e":"severe","i":"شَدِيۡدًا"},{"b":"9","h":"13.24","c":"وَشُهُبٗا","d":"washuhuban","e":"and flaming fires","i":"وَّشُهُبًاۙ"}],"a":{"g":"And we have sought [to reach] the heaven but found it filled with powerful guards and burning flames."}},"9":{"w":[{"b":"0.03","h":"0.87","c":"وَأَنَّا","d":"wa-annā","e":"And that we","i":"وَّاَنَّا"},{"b":"1.5","h":"2.9","c":"كُنَّا","d":"kunnā","e":"used (to)","i":"كُنَّا"},{"b":"2.9","h":"4.79","c":"نَقۡعُدُ","d":"naqʿudu","e":"sit","i":"نَقۡعُدُ"},{"b":"3.7","h":"6.02","c":"مِنۡهَا","d":"min'hā","e":"there in","i":"مِنۡهَا"},{"b":"4.4","h":"7.32","c":"مَقَٰعِدَ","d":"maqāʿida","e":"positions","i":"مَقَاعِدَ"},{"b":"5.4","h":"9.1","c":"لِلسَّمۡعِۖ","d":"lilssamʿi","e":"for hearing","i":"لِلسَّمۡعِؕ"},{"b":"6.8","h":"12.35","c":"فَمَن","d":"faman","e":"but (he) who","i":"فَمَنۡ"},{"b":"8.1","h":"13.68","c":"يَسۡتَمِعِ","d":"yastamiʿi","e":"listens","i":"يَّسۡتَمِعِ"},{"b":"8.9","h":"15.22","c":"ٱلۡأٓنَ","d":"l-āna","e":"now","i":"الۡاٰنَ"},{"b":"9.6","