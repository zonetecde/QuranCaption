","h":"7.76","c":"دُونَ","d":"dūna","e":"(are) other than","i":"دُوۡنَ"},{"b":"5.9","h":"8.71","c":"ذَٰلِكَۖ","d":"dhālika","e":"that","i":"ذٰلِكَؕ"},{"b":"7.1","h":"12.45","c":"كُنَّا","d":"kunnā","e":"We","i":"كُنَّا"},{"b":"8.3","h":"13.97","c":"طَرَآئِقَ","d":"ṭarāiqa","e":"(are on) ways","i":"طَرَآٮِٕقَ"},{"b":"11.","h":"16.62","c":"قِدَدٗا","d":"qidadan","e":"different","i":"قِدَدًاۙ"}],"a":{"g":"And among us are the righteous, and among us are [others] not so; we were [of] divided ways."}},"12":{"w":[{"b":"0.03","h":"0.25","c":"وَأَنَّا","d":"wa-annā","e":"And that we","i":"وَّاَنَّا"},{"b":"1.4","h":"2","c":"ظَنَنَّآ","d":"ẓanannā","e":"[we] have become certain","i":"ظَنَنَّاۤ"},{"b":"4.5","h":"3.52","c":"أَن","d":"an","e":"that","i":"اَنۡ"},{"b":"4.7","h":"5.14","c":"لَّن","d":"lan","e":"never","i":"لَّنۡ"},{"b":"5.8","h":"6.58","c":"نُّعۡجِزَ","d":"nuʿ'jiza","e":"we will cause failure","i":"نُّعۡجِزَ"},{"b":"6.5","h":"7.88","c":"ٱللَّهَ","d":"l-laha","e":"(to) Allah","i":"اللّٰهَ"},{"b":"7.3","h":"9.01","c":"فِي","d":"fī","e":"in","i":"فِى"},{"b":"7.5","h":"9.37","c":"ٱلۡأَرۡضِ","d":"l-arḍi","e":"the earth","i":"الۡاَرۡضِ"},{"b":"8.3","h":"10.57","c":"وَلَن","d":"walan","e":"and never","i":"وَلَنۡ"},{"b":"9.3","h":"11.87","c":"نُّعۡجِزَهُۥ","d":"nuʿ'jizahu","e":"we can escape Him","i":"نُّعۡجِزَهٗ"},{"b":"10.5","h":"13.96","c":"هَرَبٗا","d":"haraban","e":"(by) flight","i":"هَرَبًاۙ"}],"a":{"g":"And we have become certain that we will never cause failure to Allah upon earth, nor can we escape Him by flight."}},"13":{"w":[{"b":"0.03","h":"0.05","c":"وَأَنَّا","d":"wa-annā","e":"And that","i":"وَّاَنَّا"},{"b":"1.5","h":"1.92","c":"لَمَّا","d":"lammā","e":"when","i":"لَمَّا"},{"b":"2.7","h":"3.43","c":"سَمِعۡنَا","d":"samiʿ'nā","e":"we heard","i":"سَمِعۡنَا"},{"b":"3.5","h":"4.78","c":"ٱلۡهُدَىٰٓ","d":"l-hudā","e":"the Guidance","i":"الۡهُدٰٓى"},{"b":"5.9","h":"5.39","c":"ءَامَنَّا","d":"āmannā","e":"we believed","i":"اٰمَنَّا"},{"b":"7.7","h":"9.39","c":"