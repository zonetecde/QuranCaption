:"1.72","c":"نَخُوضُ","d":"nakhūḍu","e":"indulge in vain talk","i":"نَخُوۡضُ"},{"b":"2.4","h":"2.62","c":"مَعَ","d":"maʿa","e":"with","i":"مَعَ"},{"b":"2.7","h":"3.04","c":"ٱلۡخَآئِضِينَ","d":"l-khāiḍīna","e":"the vain talkers","i":"الۡخَـآٮِٕضِيۡنَۙ"}],"a":{"g":"And we used to enter into vain discourse with those who engaged [in it],"}},"46":{"w":[{"b":"0.03","h":"0.2","c":"وَكُنَّا","d":"wakunnā","e":"And we used (to)","i":"وَ"},{"b":"1.6","h":"1.75","c":"نُكَذِّبُ","d":"nukadhibu","e":"deny","i":"كُنَّا"},{"b":"2.5","h":"2.87","c":"بِيَوۡمِ","d":"biyawmi","e":"(the) Day","i":"نُكَذِّبُ"},{"b":"3.3","h":"3.72","c":"ٱلدِّينِ","d":"l-dīni","e":"(of) the Judgment","i":"بِيَوۡمِ الدِّيۡنِۙ"}],"a":{"g":"And we used to deny the Day of Recompense"}},"47":{"w":[{"b":"0.03","h":"0","c":"حَتَّىٰٓ","d":"ḥattā","e":"Until","i":"حَتّٰٓى"},{"b":"2.1","h":"2.13","c":"أَتَىٰنَا","d":"atānā","e":"there came to us","i":"اَتٰٮنَا"},{"b":"2.9","h":"3.08","c":"ٱلۡيَقِينُ","d":"l-yaqīnu","e":"the certainty","i":"الۡيَقِيۡنُؕ"}],"a":{"g":"Until there came to us the certainty.\""}},"48":{"w":[{"b":"0.03","h":"0.3","c":"فَمَا","d":"famā","e":"Then not","i":"فَمَا"},{"b":"0.52","h":"0.8","c":"تَنفَعُهُمۡ","d":"tanfaʿuhum","e":"will benefit them","i":"تَنۡفَعُهُمۡ"},{"b":"2.4","h":"2.68","c":"شَفَٰعَةُ","d":"shafāʿatu","e":"intercession","i":"شَفَاعَةُ"},{"b":"3.5","h":"3.84","c":"ٱلشَّـٰفِعِينَ","d":"l-shāfiʿīna","e":"(of) the intercessors","i":"الشّٰفِعِيۡنَؕ"}],"a":{"g":"So there will not benefit them the intercession of [any] intercessors."}},"49":{"w":[{"b":"0.03","h":"0.4","c":"فَمَا","d":"famā","e":"Then what","i":"فَمَا"},{"b":"0.59","h":"0.95","c":"لَهُمۡ","d":"lahum","e":"(is) for them","i":"لَهُمۡ"},{"b":"1.1","h":"1.51","c":"عَنِ","d":"ʿani","e":"(that) from","i":"عَنِ"},{"b":"1.5","h":"1.96","c":"ٱلتَّذۡكِرَةِ","d":"l-tadhkirati","e":"the Reminder","i":"التَّذۡكِرَةِ"},{"b":"2.7","h":"3.22","c":"مُعۡرِضِينَ","d":"muʿ'riḍīna","e":"they (are) turning away","i":"مُعۡرِضِيۡنَۙ"}]