{"1":{"w":[{"b":"0.03","h":"0.6","c":"وَٱلشَّمۡسِ","d":"wal-shamsi","e":"By the sun","i":"وَالشَّمۡسِ"},{"b":"1.0","h":"1.67","c":"وَضُحَىٰهَا","d":"waḍuḥāhā","e":"and its brightness","i":"وَضُحٰٮهَا ۙ"}],"a":{"g":"By the sun and its brightness"}},"2":{"w":[{"b":"0.03","h":"0.3","c":"وَٱلۡقَمَرِ","d":"wal-qamari","e":"And the moon","i":"وَالۡقَمَرِ"},{"b":"1.0","h":"1.44","c":"إِذَا","d":"idhā","e":"when","i":"اِذَا"},{"b":"1.6","h":"2.26","c":"تَلَىٰهَا","d":"talāhā","e":"it follows it","i":"تَلٰٮهَا ۙ"}],"a":{"g":"And [by] the moon when it follows it"}},"3":{"w":[{"b":"0.03","h":"0.3","c":"وَٱلنَّهَارِ","d":"wal-nahāri","e":"And the day","i":"وَالنَّهَارِ"},{"b":"2.1","h":"2.26","c":"إِذَا","d":"idhā","e":"when","i":"اِذَا"},{"b":"2.8","h":"3.15","c":"جَلَّىٰهَا","d":"jallāhā","e":"it displays it","i":"جَلّٰٮهَاۙ"}],"a":{"g":"And [by] the day when it displays it"}},"4":{"w":[{"b":"0.03","h":"0.25","c":"وَٱلَّيۡلِ","d":"wa-al-layli","e":"And the night","i":"وَالَّيۡلِ"},{"b":"1.0","h":"1.72","c":"إِذَا","d":"idhā","e":"when","i":"اِذَا"},{"b":"1.6","h":"2.72","c":"يَغۡشَىٰهَا","d":"yaghshāhā","e":"it covers it","i":"يَغۡشٰٮهَاۙ"}],"a":{"g":"And [by] the night when it covers it"}},"5":{"w":[{"b":"0.03","h":"0.6","c":"وَٱلسَّمَآءِ","d":"wal-samāi","e":"And the heaven","i":"وَالسَّمَآءِ"},{"b":"2.6","h":"3.56","c":"وَمَا","d":"wamā","e":"and He Who","i":"وَمَا"},{"b":"3.2","h":"4.57","c":"بَنَىٰهَا","d":"banāhā","e":"constructed it","i":"بَنٰٮهَاۙ"}],"a":{"g":"And [by] the sky and He who constructed it"}},"6":{"w":[{"b":"0.03","h":"0.25","c":"وَٱلۡأَرۡضِ","d":"wal-arḍi","e":"And the earth","i":"وَالۡاَرۡضِ"},{"b":"1.0","h":"1.72","c":"وَمَا","d":"wamā","e":"and He Who","i":"وَمَا"},{"b":"1.6","h":"2.76","c":"طَحَىٰهَا","d":"ṭaḥāhā","e":"spread it","i":"طَحٰٮهَاۙ"}],"a":{"g":"And [by] the earth and He who spread it"}},"7":{"w":[{"b":"0.03","h":"0.4","c":"وَنَفۡسٖ","d":"wanafsin","e":"And (the) soul","i":"وَنَفۡسٍ"},{"b":"0.94","h":"2.39","c":"وَمَا","d":"wamā","e":"and He Who","i":"وَّمَا"},{"b":"2.2","h":"3.42","c":"سَوَّىٰهَا","d":"sawwāhā","e":"proportioned it","i":"سَوّٰٮهَاۙ"}],"a":{"g":"And [by] the soul and He who proportioned it"}},"8":{"w":[{"b":"0.03","h":"0.5","c":"فَأَلۡهَمَهَا","d":"fa-alhamahā","e":"And He inspired it","i":"فَاَلۡهَمَهَا"},{"b":"1.3","h":"2.56","c":"فُجُورَهَا","d":"fujūrahā","e":"(to understand) what is wrong for it","i":"فُجُوۡرَهَا"},{"b":"2.7","h":"5.03","c":"وَتَقۡوَىٰهَا","d":"wataqwāhā","e":"and what is right for it","i":"وَتَقۡوٰٮهَاۙ"}],"a":{"g":"And inspired it [with discernment of] its wickedness and its righteousness,"}},"9":{"w":[{"b":"0.03","h":"1.2","c":"قَدۡ","d":"qad","e":"Indeed","i":"قَدۡ"},{"b":"0.35","h":"1.77","c":"أَفۡلَحَ","d":"aflaḥa","e":"he succeeds","i":"اَفۡلَحَ"},{"b":"1.2","h":"3.03","c":"مَن","d":"man","e":"who","i":"مَنۡ"},{"b":"2.1","h":"4.2","c":"زَكَّىٰهَا","d":"zakkāhā","e":"purifies it","i":"زَكّٰٮهَاۙ"}],"a":{"g":"He has succeeded who purifies it,"}},"10":{"w":[{"b":"0.03","h":"0.3","c":"وَقَدۡ","d":"waqad","e":"And indeed","i":"وَقَدۡ"},{"b":"0.51","h":"0.96","c":"خَابَ","d":"khāba","e":"he fails","i":"خَابَ"},{"b":"1.2","h":"2.26","c":"مَن","d":"man","e":"who","i":"مَنۡ"},{"b":"2.3","h":"3.64","c":"دَسَّىٰهَا","d":"dassāhā","e":"corrupts it","i":"دَسّٰٮهَاؕ"}],"a":{"g":"And he has failed who instills it [with corruption]."}},"11":{"w":[{"b":"0.03","h":"0.75","c":"كَذَّبَتۡ","d":"kadhabat","e":"Denied","i":"كَذَّبَتۡ"},{"b":"0.88","h":"2.05","c":"ثَمُودُ","d":"thamūdu","e":"Thamud","i":"ثَمُوۡدُ"},{"b":"1.8","h":"3.62","c":"بِطَغۡوَىٰهَآ","d":"biṭaghwāhā","e":"by their transgression","i":"بِطَغۡوٰٮهَآ ۙ"}],"a":{"g":"Thamud denied [their prophet] by reason of their transgression,"}},"12":{"w":[{"b":"0.03","h":"0.03","c":"إِذِ","d":"idhi","e":"When","i":"اِذِ"},{"b":"0.39","h":"0.63","c":"ٱنۢبَعَثَ","d":"inbaʿatha","e":"(was) sent forth","i":"انۡۢبَعَثَ"},{"b":"1.8","h":"2.56","c":"أَشۡقَىٰهَا","d":"ashqāhā","e":"(the) most wicked of them","i":"اَشۡقٰٮهَا ۙ"}],"a":{"g":"When the most wretched of them was sent forth."}},"13":{"w":[{"b":"0.03","h":"1.25","c":"فَقَالَ","d":"faqāla","e":"But said","i":"فَقَالَ"},{"b":"0.85","h":"2.41","c":"لَهُمۡ","d":"lahum","e":"to them","i":"لَهُمۡ"},{"b":"1.4","h":"3.36","c":"رَسُولُ","d":"rasūlu","e":"(the) Messenger","i":"رَسُوۡلُ"},{"b":"2.3","h":"4.76","c":"ٱللَّهِ","d":"l-lahi","e":"(of) Allah","i":"اللّٰهِ"},{"b":"3.2","h":"5.96","c":"نَاقَةَ","d":"nāqata","e":"(It is the) she-camel","i":"نَاقَةَ"},{"b":"4.0","h":"7.26","c":"ٱللَّهِ","d":"l-lahi","e":"(of) Allah","i":"اللّٰهِ"},{"b":"4.9","h":"8.56","c":"وَسُقۡيَٰهَا","d":"wasuq'yāhā","e":"and her drink","i":"وَسُقۡيٰهَاؕ"}],"a":{"g":"And the messenger of Allah [Salih] said to them, \"[Do not harm] the she-camel of Allah or [prevent her from] her drink.\""}},"14":{"w":[{"b":"0.03","h":"0.75","c":"فَكَذَّبُوهُ","d":"fakadhabūhu","e":"But they denied him","i":"فَكَذَّبُوۡهُ"},{"b":"1.4","h":"2.82","c":"فَعَقَرُوهَا","d":"faʿaqarūhā","e":"and they hamstrung her","i":"فَعَقَرُوۡهَا "},{"b":"2.9","h":"5.33","c":"فَدَمۡدَمَ","d":"fadamdama","e":"So destroyed","i":"ۙفَدَمۡدَمَ"},{"b":"3.9","h":"6.83","c":"عَلَيۡهِمۡ","d":"ʿalayhim","e":"them","i":"عَلَيۡهِمۡ"},{"b":"5.0","h":"8.55","c":"رَبُّهُم","d":"rabbuhum","e":"their Lord","i":"رَبُّهُمۡ"},{"b":"6.8","h":"10.71","c":"بِذَنۢبِهِمۡ","d":"bidhanbihim","e":"for their sin","i":"بِذَنۡۢبِهِمۡ"},{"b":"8.6","h":"13.09","c":"فَسَوَّىٰهَا","d":"fasawwāhā","e":"and leveled them","i":"فَسَوّٰٮهَا ۙ"}],"a":{"g":"But they denied him and hamstrung her. So their Lord brought down upon them destruction for their sin and made it equal [upon all of them]."}},"15":{"w":[{"b":"0.03","h":"0.45","c":"وَلَا","d":"walā","e":"And not","i":"وَلَا"},{"b":"0.67","h":"1.3","c":"يَخَافُ","d":"yakhāfu","e":"He fears","i":"يَخَافُ"},{"b":"1.7","h":"2.78","c":"عُقۡبَٰهَا","d":"ʿuq'bāhā","e":"its consequences","i":"عُقۡبٰهَا"}],"a":{"g":"And He does not fear the consequence thereof."}}}