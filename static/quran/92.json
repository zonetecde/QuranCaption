{"1":{"w":[{"b":"0.03","h":"0.45","c":"وَٱلَّيۡلِ","d":"wa-al-layli","e":"By the night","i":"وَالَّيۡلِ"},{"b":"1.0","h":"1.89","c":"إِذَا","d":"idhā","e":"when","i":"اِذَا"},{"b":"1.6","h":"2.93","c":"يَغۡشَىٰ","d":"yaghshā","e":"it covers","i":"يَغۡشٰىۙ"}],"a":{"g":"By the night when it covers"}},"2":{"w":[{"b":"0.03","h":"0.25","c":"وَٱلنَّهَارِ","d":"wal-nahāri","e":"And the day","i":"وَالنَّهَارِ"},{"b":"1.9","h":"2.61","c":"إِذَا","d":"idhā","e":"when","i":"اِذَا"},{"b":"2.5","h":"3.59","c":"تَجَلَّىٰ","d":"tajallā","e":"it shines in brightness","i":"تَجَلّٰىۙ"}],"a":{"g":"And [by] the day when it appears"}},"3":{"w":[{"b":"0.03","h":"0.41","c":"وَمَا","d":"wamā","e":"And He Who","i":"وَمَا"},{"b":"0.56","h":"1.19","c":"خَلَقَ","d":"khalaqa","e":"created","i":"خَلَقَ"},{"b":"1.2","h":"2.27","c":"ٱلذَّكَرَ","d":"l-dhakara","e":"the male","i":"الذَّكَرَ"},{"b":"2.1","h":"3.73","c":"وَٱلۡأُنثَىٰٓ","d":"wal-unthā","e":"and the female","i":"وَالۡاُنۡثٰٓىۙ"}],"a":{"g":"And [by] He who created the male and female,"}},"4":{"w":[{"b":"0.03","h":"0.35","c":"إِنَّ","d":"inna","e":"Indeed","i":"اِنَّ"},{"b":"1.2","h":"1.66","c":"سَعۡيَكُمۡ","d":"saʿyakum","e":"your efforts","i":"سَعۡيَكُمۡ"},{"b":"2.4","h":"3.48","c":"لَشَتَّىٰ","d":"lashattā","e":"(are) surely diverse","i":"لَشَتّٰىؕ"}],"a":{"g":"Indeed, your efforts are diverse."}},"5":{"w":[{"b":"0.03","h":"0.6","c":"فَأَمَّا","d":"fa-ammā","e":"Then as for","i":"فَاَمَّا"},{"b":"1.7","h":"2.49","c":"مَنۡ","d":"man","e":"(him) who","i":"مَنۡ"},{"b":"2.1","h":"3.17","c":"أَعۡطَىٰ","d":"aʿṭā","e":"gives","i":"اَعۡطٰى"},{"b":"2.9","h":"4.86","c":"وَٱتَّقَىٰ","d":"wa-ittaqā","e":"and fears","i":"وَاتَّقٰىۙ"}],"a":{"g":"As for he who gives and fears Allah"}},"6":{"w":[{"b":"0.04","h":"0.5","c":"وَصَدَّقَ","d":"waṣaddaqa","e":"And believes","i":"وَصَدَّقَ"},{"b":"1.0","h":"2.12","c":"بِٱلۡحُسۡنَىٰ","d":"bil-ḥus'nā","e":"in the best","i":"بِالۡحُسۡنٰىۙ"}],"a":{"g":"And believes in the best [reward],"}},"7":{"w":[{"b":"0.03","